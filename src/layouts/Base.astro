---
import '../styles/globals.css';
import OperatorChrome from '../components/OperatorChrome.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  section?: string;
  pathname?: string;
  serial?: string;
}
const {
  title,
  description = 'An archive of the May 2026 PURSUE UFO file release and FBI 62-HQ-83894.',
} = Astro.props;

const fullTitle = title === 'The UFO Files' ? title : `${title} — The UFO Files`;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname;
const pathname = Astro.url.pathname;

/**
 * Route to mode mapping.
 * LIGHT (reading): /dossier/[slug], /entity/[slug], /about
 * DARK (cinematic): everything else (/, /board, /atlas, /map,
 *   /timeline, /thread/[id], /evidence/[slug], /saved, /404)
 */
function resolveMode(path: string): 'dark' | 'light' {
  if (path.startsWith('/dossier/')) return 'light';
  if (path.startsWith('/entity/')) return 'light';
  if (path === '/about' || path === '/about/') return 'light';
  return 'dark';
}
const mode = resolveMode(pathname);
const themeColor = mode === 'dark' ? '#000000' : '#ffffff';
---
<!doctype html>
<html lang="en" data-mode={mode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content={themeColor} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <link rel="canonical" href={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="page-shell">
      <OperatorChrome pathname={pathname} />
      <main id="main" class="page-main">
        <slot />
      </main>
      <footer class="page-footer">
        <span>The UFO Files</span>
        <span class="page-footer__sep">/</span>
        <span>An archive by <a href="https://deadpixeldesign.com" rel="noopener external">Dead Pixel Design</a></span>
        <span class="page-footer__sep">/</span>
        <a href="https://github.com/wretcher207/the-ufo-files" rel="noopener external">Github</a>
        <span class="page-footer__sep">/</span>
        <span>Released May 8 2026</span>
      </footer>
    </div>
  </body>
</html>
</content>
</invoke>