---
import Base from '../layouts/Base.astro';
import { archiveOf, getRenderableCases, headlineDate, tidyTitle } from '../lib/case-utils';

const all = await getRenderableCases();

function parseDate(s) {
  if (!s) return null;
  const m = String(s).match(/(\d{4})(?:-(\d{1,2}))?/);
  if (!m) return null;
  return { y: parseInt(m[1], 10), mo: m[2] ? parseInt(m[2], 10) : 6 };
}

const marks = [];
for (const c of all) {
  const date = parseDate(headlineDate(c));
  if (!date || date.y < 1944 || date.y > 2030) continue;
  marks.push({
    slug: c.id,
    title: tidyTitle(c.data.title),
    archive: archiveOf(c),
    significance: c.data.significance ?? 'medium',
    year: date.y,
    month: date.mo,
    display: date.y + '-' + String(date.mo).padStart(2, '0'),
  });
}
marks.sort((a, b) => a.year - b.year || a.month - b.month);

// Stack markers vertically when they cluster too closely on the time axis.
const ROW_HEIGHT_PCT = 22; // vertical row spacing (relative to the marks-list height)
const ROW_COUNT = 4;
const placedX = [];
for (const m of marks) {
  const xPct = ((m.year - 1944 + (m.month - 1) / 12) / (2026 - 1944)) * 100;
  let row = 0;
  for (let r = 0; r < ROW_COUNT; r++) {
    const used = placedX.some((p) => p.row === r && Math.abs(p.x - xPct) < 0.9);
    if (!used) { row = r; break; }
    if (r === ROW_COUNT - 1) row = m.year % ROW_COUNT;
  }
  m.row = row;
  m.xPct = xPct;
  placedX.push({ row, x: xPct });
}

const earliest = 1944;
const latest = 2026;
const span = latest - earliest;
const pct = (y, m) => ((y - earliest + (m - 1) / 12) / span) * 100;

const decadeTicks = [];
for (let y = earliest; y <= latest; y++) {
  if (y % 10 === 0) decadeTicks.push(y);
}
---
<Base
  title="Timeline"
  description="Every dated case in the archive, 1944 to 2026."
  section="ALL THREADS"
>
  <main class="tl-main" id="main">

    <a class="ufo-section-anchor tl-anchor" href="/threads">
      <span class="ufo-section-anchor__num">{marks.length}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Dated cases plotted</span>
        <span class="ufo-section-anchor__sublabel">1944 → 2026 &nbsp;/&nbsp; 82-year span</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Read by thread</span>
    </a>

    <header class="tl-hero">
      <h1 class="tl-hero__title">Eighty years of the file.</h1>
      <p class="tl-hero__lede">
        Every case with an extractable date. Hover or focus a marker for the title.
        Click to open. The empty stretch between 1973 and 2025 is deliberate; no archive ran there.
      </p>
    </header>

  <div class="tl-board" role="region" aria-label="Timeline of UFO cases">
    <div class="tl-board__axis" aria-hidden="true">
      {decadeTicks.map((y) => (
        <div class="tl-tick" style={'left:' + ((y - earliest) / span) * 100 + '%'}>
          <span class="tl-tick__label">{y}</span>
        </div>
      ))}
    </div>

    <ul class="tl-board__marks">
      {marks.map((m) => (
        <li class={'tl-mark tl-mark--' + m.archive + ' tl-mark--' + m.significance} style={'left:' + m.xPct + '%; top:' + (12 + m.row * ROW_HEIGHT_PCT) + '%'}>
          <a href={'/dossier/' + m.slug} aria-label={m.display + ' ' + m.title}>
            <span class="tl-mark__dot" aria-hidden="true"></span>
            <span class="tl-mark__tip">
              <span class="tl-mark__tip-date">{m.display}</span>
              <span class="tl-mark__tip-archive">{m.archive === 'pursue' ? 'PURSUE' : 'FBI'}</span>
              <span class="tl-mark__tip-title">{m.title}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <p class="tl-help">Scroll horizontally to navigate. Tab to step through cases.</p>

  <section class="tl-legend">
    <h2 class="tl-legend__title">Legend</h2>
    <ul class="tl-legend__list">
      <li><span class="tl-mark__dot tl-mark--fbi tl-mark--high"></span> FBI high-signal</li>
      <li><span class="tl-mark__dot tl-mark--fbi tl-mark--medium"></span> FBI medium</li>
      <li><span class="tl-mark__dot tl-mark--fbi tl-mark--low"></span> FBI low</li>
      <li><span class="tl-mark__dot tl-mark--pursue tl-mark--high"></span> PURSUE (outlined)</li>
    </ul>
  </section>

  </main>
</Base>

<style>
  .tl-main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }
  @media (max-width: 720px) {
    .tl-main { padding: 48px 16px 80px; }
  }

  .tl-anchor { margin-bottom: 56px; }
  @media (max-width: 720px) {
    .tl-anchor { margin-bottom: 40px; }
  }

  .tl-hero { margin: 0 0 64px; max-width: 70ch; }
  .tl-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 24px;
    max-width: 18ch;
  }
  .tl-hero__lede {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-mid);
    margin: 0;
  }

  .tl-board {
    position: relative;
    overflow-x: auto;
    overflow-y: visible;
    padding: 56px 0 64px;
    border-top: 1px solid var(--fg);
    border-bottom: 1px solid var(--fg);
    background: var(--bg);
  }
  .tl-board__axis {
    position: relative;
    height: 36px;
    margin: 0 24px 32px;
    min-width: 1200px;
    border-bottom: 1px solid var(--rule);
  }
  .tl-tick {
    position: absolute;
    top: 0;
    width: 1px;
    height: 16px;
    background: var(--fg);
  }
  .tl-tick__label {
    position: absolute;
    top: 18px;
    left: 0;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-mid);
    letter-spacing: 0.18em;
  }
  .tl-board__marks {
    position: relative;
    height: 160px;
    margin: 0 24px;
    list-style: none;
    padding: 0;
    min-width: 1200px;
  }
  .tl-mark { position: absolute; transform: translate(-50%, -50%); }
  .tl-mark a {
    display: block;
    width: 14px;
    height: 14px;
    position: relative;
  }
  .tl-mark a:focus-visible { outline: none; }
  .tl-mark__dot {
    position: absolute;
    inset: 4px;
    background: var(--fg-mid);
    transition: inset var(--dur-quick) linear,
                background var(--dur-quick) linear;
  }
  .tl-mark--fbi .tl-mark__dot { background: var(--fg-mid); }
  .tl-mark--pursue .tl-mark__dot {
    background: var(--bg);
    box-shadow: inset 0 0 0 1.5px var(--fg);
  }
  .tl-mark--high .tl-mark__dot { inset: 1px; }
  .tl-mark--low .tl-mark__dot { inset: 5px; opacity: 0.6; }
  .tl-mark a:hover .tl-mark__dot,
  .tl-mark a:focus-visible .tl-mark__dot {
    inset: 0;
    background: var(--fg);
    box-shadow: none;
  }
  .tl-mark__tip {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    border: 1px solid var(--fg);
    padding: 10px 14px;
    min-width: 240px;
    max-width: 320px;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-quick) linear;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 5;
  }
  .tl-mark a:hover .tl-mark__tip,
  .tl-mark a:focus-visible .tl-mark__tip {
    opacity: 1;
    pointer-events: auto;
  }
  .tl-mark__tip-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--fg-mid);
  }
  .tl-mark__tip-archive {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg);
  }
  .tl-mark__tip-title {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--fg);
    line-height: 1.25;
  }
  .tl-help {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-dim);
    margin: 24px 0 64px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .tl-legend {
    border-top: 1px solid var(--rule);
    padding-top: 32px;
  }
  .tl-legend__title {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg);
    margin: 0 0 24px;
    font-weight: 500;
  }
  .tl-legend__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-mid);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .tl-legend__list li { display: flex; align-items: center; gap: 8px; }
  .tl-legend__list .tl-mark__dot {
    position: relative;
    inset: auto;
    width: 12px;
    height: 12px;
    display: inline-block;
  }
  .tl-legend__list .tl-mark--high.tl-mark__dot { width: 14px; height: 14px; }
  .tl-legend__list .tl-mark--low.tl-mark__dot { opacity: 0.6; }
</style>
