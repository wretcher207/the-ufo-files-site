---
import Base from '../layouts/Base.astro';
import { archiveOf, getRenderableCases, headlineDate, tidyTitle } from '../lib/case-utils';

const all = await getRenderableCases();

function parseDate(s) {
  if (!s) return null;
  const m = String(s).match(/(\d{4})(?:-(\d{1,2}))?/);
  if (!m) return null;
  return { y: parseInt(m[1], 10), mo: m[2] ? parseInt(m[2], 10) : 6 };
}

const marks = [];
for (const c of all) {
  const date = parseDate(headlineDate(c));
  if (!date || date.y < 1944 || date.y > 2030) continue;
  marks.push({
    slug: c.id,
    title: tidyTitle(c.data.title),
    archive: archiveOf(c),
    significance: c.data.significance ?? 'medium',
    year: date.y,
    month: date.mo,
    display: date.y + '-' + String(date.mo).padStart(2, '0'),
  });
}
marks.sort((a, b) => a.year - b.year || a.month - b.month);

// Stack markers vertically when they cluster too closely on the time axis.
const ROW_HEIGHT_PCT = 22; // vertical row spacing (relative to the marks-list height)
const ROW_COUNT = 4;
const placedX = [];
for (const m of marks) {
  const xPct = ((m.year - 1944 + (m.month - 1) / 12) / (2026 - 1944)) * 100;
  let row = 0;
  for (let r = 0; r < ROW_COUNT; r++) {
    const used = placedX.some((p) => p.row === r && Math.abs(p.x - xPct) < 0.9);
    if (!used) { row = r; break; }
    if (r === ROW_COUNT - 1) row = m.year % ROW_COUNT;
  }
  m.row = row;
  m.xPct = xPct;
  placedX.push({ row, x: xPct });
}

const earliest = 1944;
const latest = 2026;
const span = latest - earliest;
const pct = (y, m) => ((y - earliest + (m - 1) / 12) / span) * 100;

const decadeTicks = [];
for (let y = earliest; y <= latest; y++) {
  if (y % 10 === 0) decadeTicks.push(y);
}
---
<Base
  title="Timeline"
  description="Every dated case in the archive, 1944 to 2026."
  serial="TIMELINE"
  section="ALL THREADS"
>
  <header class="tl-hero">
    <div class="tl-hero__breadcrumb">
      <a href="/">Case board</a> <span aria-hidden="true">/</span> <span>Timeline</span>
    </div>
    <p class="tl-hero__eyebrow">{marks.length} dated cases plotted</p>
    <h1 class="tl-hero__title">Eighty years of the file.</h1>
    <p class="tl-hero__lede">
      Every case in the archive with an extractable date. Hover or focus a marker to read the title;
      click to open the dossier. PURSUE markers glow.
    </p>
  </header>

  <div class="tl-board" role="region" aria-label="Timeline of UFO cases">
    <div class="tl-board__axis" aria-hidden="true">
      {decadeTicks.map((y) => (
        <div class="tl-tick" style={'left:' + ((y - earliest) / span) * 100 + '%'}>
          <span class="tl-tick__label">{y}</span>
        </div>
      ))}
    </div>

    <ul class="tl-board__marks">
      {marks.map((m) => (
        <li class={'tl-mark tl-mark--' + m.archive + ' tl-mark--' + m.significance} style={'left:' + m.xPct + '%; top:' + (12 + m.row * ROW_HEIGHT_PCT) + '%'}>
          <a href={'/dossier/' + m.slug} aria-label={m.display + ' ' + m.title}>
            <span class="tl-mark__dot" aria-hidden="true"></span>
            <span class="tl-mark__tip">
              <span class="tl-mark__tip-date">{m.display}</span>
              <span class="tl-mark__tip-archive">{m.archive === 'pursue' ? 'PURSUE' : 'FBI'}</span>
              <span class="tl-mark__tip-title">{m.title}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <p class="tl-help">Scroll horizontally to navigate. Tab to step through cases.</p>

  <section class="tl-legend">
    <h2 class="tl-legend__title">Legend</h2>
    <ul class="tl-legend__list">
      <li><span class="tl-mark__dot tl-mark--fbi tl-mark--high"></span> FBI high-signal</li>
      <li><span class="tl-mark__dot tl-mark--fbi tl-mark--medium"></span> FBI medium</li>
      <li><span class="tl-mark__dot tl-mark--fbi tl-mark--low"></span> FBI low</li>
      <li><span class="tl-mark__dot tl-mark--pursue tl-mark--high"></span> PURSUE</li>
    </ul>
  </section>
</Base>

<style>
  .tl-hero { padding: var(--sp-5) 0 var(--sp-6); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: var(--sp-6); }
  .tl-hero__breadcrumb { font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: var(--tracking-wide); color: var(--fg-3); display: flex; gap: var(--sp-2); margin-bottom: var(--sp-4); }
  .tl-hero__breadcrumb a { color: var(--fg-2); }
  .tl-hero__eyebrow { font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--fg-3); margin: 0 0 var(--sp-3); }
  .tl-hero__title { font-family: var(--font-display); font-size: var(--fs-3xl); line-height: var(--lh-tight); letter-spacing: var(--tracking-tight); color: var(--fg-1); margin: 0 0 var(--sp-4); font-weight: 500; max-width: 22ch; }
  @media (max-width: 640px) { .tl-hero__title { font-size: var(--fs-2xl); } }
  .tl-hero__lede { font-family: var(--font-ui); font-size: var(--fs-md); line-height: var(--lh-loose); color: var(--fg-2); max-width: 70ch; margin: 0; }
  .tl-board { position: relative; overflow-x: auto; overflow-y: visible; padding: var(--sp-6) 0 var(--sp-8); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-1); }
  .tl-board__axis { position: relative; height: 36px; margin: 0 var(--sp-5) var(--sp-4); min-width: 1200px; border-bottom: 1px solid var(--border); }
  .tl-tick { position: absolute; top: 0; width: 1px; height: 16px; background: var(--border-strong); }
  .tl-tick__label { position: absolute; top: 18px; left: 0; transform: translateX(-50%); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--fg-3); letter-spacing: var(--tracking-wide); }
  .tl-board__marks { position: relative; height: 130px; margin: 0 var(--sp-5); list-style: none; padding: 0; min-width: 1200px; }
  .tl-mark { position: absolute; transform: translate(-50%, -50%); }
  .tl-mark a { display: block; width: 14px; height: 14px; position: relative; }
  .tl-mark a:focus-visible { outline: none; }
  .tl-mark a:focus-visible .tl-mark__dot { box-shadow: var(--focus-ring); }
  .tl-mark__dot { position: absolute; inset: 4px; background: var(--fg-3); transition: inset var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out); }
  .tl-mark--fbi .tl-mark__dot { background: var(--dead-silver); }
  .tl-mark--pursue .tl-mark__dot { background: var(--crt-glow); box-shadow: 0 0 6px rgba(199, 247, 255, 0.6); }
  .tl-mark--high .tl-mark__dot { inset: 2px; }
  .tl-mark--low .tl-mark__dot { inset: 5px; opacity: 0.7; }
  .tl-mark a:hover .tl-mark__dot, .tl-mark a:focus-visible .tl-mark__dot { inset: 1px; background: var(--crt-glow); box-shadow: 0 0 10px rgba(199, 247, 255, 0.6); }
  .tl-mark__tip { position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--bg-2); border: 1px solid var(--border-strong); padding: var(--sp-2) var(--sp-3); min-width: 240px; max-width: 320px; opacity: 0; pointer-events: none; transition: opacity var(--dur-fast) var(--ease-out); display: flex; flex-direction: column; gap: 2px; z-index: 5; }
  .tl-mark a:hover .tl-mark__tip, .tl-mark a:focus-visible .tl-mark__tip { opacity: 1; pointer-events: auto; }
  .tl-mark__tip-date { font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wide); color: var(--fg-3); }
  .tl-mark__tip-archive { font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wider); color: var(--fg-2); }
  .tl-mark__tip-title { font-family: var(--font-ui); font-size: var(--fs-sm); color: var(--fg-1); line-height: var(--lh-snug); }
  .tl-help { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--fg-3); margin: var(--sp-4) 0 var(--sp-7); letter-spacing: var(--tracking-wide); }
  .tl-legend { border-top: 1px solid var(--border); padding-top: var(--sp-5); }
  .tl-legend__title { font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--fg-3); margin: 0 0 var(--sp-4); font-weight: 500; }
  .tl-legend__list { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--sp-5); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--fg-2); letter-spacing: var(--tracking-wide); }
  .tl-legend__list li { display: flex; align-items: center; gap: var(--sp-2); }
  .tl-legend__list .tl-mark__dot { position: relative; inset: auto; width: 12px; height: 12px; display: inline-block; }
  .tl-legend__list .tl-mark--high.tl-mark__dot { width: 14px; height: 14px; }
  .tl-legend__list .tl-mark--low.tl-mark__dot { opacity: 0.7; }
</style>
