---
import Base from '../layouts/Base.astro';
---
<Base
  title="Source Vault"
  description="Direct access to original source material: PDFs, FBI 302s, AARO sheets, OCR transcripts, video, and stills."
  serial="VAULT/PREVIEW"
  section="SOURCE VAULT"
>
  <section class="section" style="margin-top: var(--sp-7);">
    <header class="section__head">
      <div class="section__title-block">
        <span class="section__eyebrow">MOD-06 · Investigation mode</span>
        <h1 class="section__title">Source Vault</h1>
      </div>
      <span class="section__meta">Building · Phase 4</span>
    </header>

    <div class="coming-soon">
      <span class="coming-soon__label">Under construction</span>
      <h2 class="coming-soon__title">Direct access to the original material.</h2>
      <p class="coming-soon__body">
        The Vault will catalog every PDF, FBI 302, AARO sheet, OCR transcript, video, and image
        in the archive. Filterable by source type, agency, release batch, OCR status, and
        whether the source has a curated dossier attached.
      </p>
      <p class="coming-soon__body">
        While the Vault is being built, source material is reachable inside each dossier.
      </p>
      <div class="wake__actions" style="margin-top: var(--sp-4);">
        <a class="btn" href="/">Case board</a>
        <a class="btn" href="https://github.com/wretcher207/the-ufo-files" rel="noopener external">Raw archive on GitHub</a>
        <a class="btn btn--primary" href="https://www.war.gov/UFO/" rel="noopener external">Originals at war.gov</a>
      </div>
    </div>
  </section>
</Base>
