---
import Base from '../../layouts/Base.astro';
import { THREADS } from '../../lib/threads';
import {
  allThreadIds,
  archiveOf,
  caseUrl,
  getRenderableCases,
  headlineDate,
  tidyTitle,
} from '../../lib/case-utils';
import { caseImage } from '../../lib/case-images';

export async function getStaticPaths() {
  return THREADS.map((thread) => ({
    params: { id: thread.id },
    props: { thread },
  }));
}

const { thread } = Astro.props;
const all = await getRenderableCases();
const cases = all.filter((c) => allThreadIds(c).includes(thread.id));

cases.sort((a, b) => {
  const da = headlineDate(a) ?? '';
  const db = headlineDate(b) ?? '';
  return da.localeCompare(db);
});

const totalSig = (sig: string) => cases.filter((c) => (c.data.significance ?? 'medium') === sig).length;
const highCount = totalSig('high');

// Find this thread's position in the canonical sequence for the eyebrow.
const threadIdx = THREADS.findIndex((t) => t.id === thread.id);
const prevThread = threadIdx > 0 ? THREADS[threadIdx - 1] : null;
const nextThread = threadIdx >= 0 && threadIdx < THREADS.length - 1 ? THREADS[threadIdx + 1] : null;

const archiveLabel = thread.archive === 'pursue' ? 'PURSUE' : 'FBI 62-HQ-83894';
---
<Base
  title={thread.title}
  description={thread.blurb}
  section="THREAD"
>
  <main class="thread-main" id="main">

    <a class="ufo-section-anchor thread-anchor" href="/threads">
      <span class="ufo-section-anchor__num">{String(threadIdx + 1).padStart(2, '0')}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">{archiveLabel} &nbsp;/&nbsp; Thread</span>
        <span class="ufo-section-anchor__sublabel">{thread.serial}</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ All threads</span>
    </a>

    <header class="thread-hero">
      <h1 class="thread-hero__title">{thread.title}.</h1>
      <p class="thread-hero__span">{thread.span}</p>
      <p class="thread-hero__blurb">{thread.blurb}</p>
      <p class="thread-hero__count">
        <a href="/timeline">{cases.length} case{cases.length === 1 ? '' : 's'} in this thread</a>
        {highCount > 0 && <> &nbsp;/&nbsp; {highCount} headline {highCount === 1 ? 'read' : 'reads'}</>}
      </p>
    </header>

    {cases.length === 0 ? (
      <p class="thread-empty">
        No cases sit in this thread yet. The
        <a href="/timeline"> timeline </a>
        shows everything that does.
      </p>
    ) : (
      <ol class="thread-list">
        {cases.map((c, i) => {
          const img = caseImage(c.id);
          const sig = String(c.data.significance ?? 'medium').toLowerCase();
          return (
            <li class="thread-row">
              <a href={caseUrl(c)} class="thread-row__link ufo-row-link">
                <span class="thread-row__num ufo-row-link__dim">{String(i + 1).padStart(2, '0')}</span>
                <span class="thread-row__thumb">
                  {img && <img src={img.src} alt="" width="80" height="56" loading="lazy" />}
                </span>
                <span class="thread-row__date ufo-row-link__mid">{headlineDate(c) ?? '----'}</span>
                <span class="thread-row__title ufo-row-link__fg">{tidyTitle(c.data.title)}</span>
                <span class={`thread-row__sig thread-row__sig--${sig} ufo-row-link__dim`}>{sig === 'high' ? 'HEADLINE' : sig.toUpperCase()}</span>
                <span class="thread-row__agency ufo-row-link__dim">{archiveOf(c) === 'pursue' ? 'PURSUE' : 'FBI'}</span>
              </a>
            </li>
          );
        })}
      </ol>
    )}

    <nav class="thread-nav" aria-label="Adjacent threads">
      {prevThread ? (
        <a class="thread-nav__link thread-nav__link--prev" href={`/thread/${prevThread.id}`}>
          <span class="thread-nav__arrow">↩</span>
          <span class="thread-nav__body">
            <span class="thread-nav__eyebrow">PREVIOUS THREAD</span>
            <span class="thread-nav__title">{prevThread.title}</span>
          </span>
        </a>
      ) : <span></span>}
      {nextThread ? (
        <a class="thread-nav__link thread-nav__link--next" href={`/thread/${nextThread.id}`}>
          <span class="thread-nav__body">
            <span class="thread-nav__eyebrow">NEXT THREAD</span>
            <span class="thread-nav__title">{nextThread.title}</span>
          </span>
          <span class="thread-nav__arrow">↪</span>
        </a>
      ) : <span></span>}
    </nav>

  </main>
</Base>

<style>
  .thread-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6) var(--sp-8);
  }
  @media (max-width: 720px) {
    .thread-main { padding: var(--sp-6) var(--sp-4) var(--sp-7); }
  }

  .thread-anchor { margin-bottom: var(--sp-7); }
  @media (max-width: 720px) {
    .thread-anchor { margin-bottom: var(--sp-6); }
  }

  .thread-hero { margin: 0 0 var(--sp-7); }
  .thread-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 var(--sp-5);
    max-width: 18ch;
  }
  .thread-hero__span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-mid);
    margin: 0 0 var(--sp-5);
  }
  .thread-hero__blurb {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-mid);
    max-width: 60ch;
    margin: 0 0 var(--sp-6);
  }
  .thread-hero__count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0;
  }
  .thread-hero__count a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .thread-hero__count a:hover,
  .thread-hero__count a:focus-visible {
    border-bottom-color: var(--fg);
  }

  .thread-empty {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.4;
    color: var(--fg-mid);
    max-width: 40ch;
    margin: var(--sp-6) 0 var(--sp-7);
  }
  .thread-empty a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 4px;
  }
  .thread-empty a:hover { text-decoration-color: var(--fg); }

  .thread-list { margin: 0; padding: 0; list-style: none; }
  .thread-row { border-bottom: 1px solid var(--rule); }
  .thread-row__link {
    grid-template-columns: var(--sp-6) var(--sp-8) calc(var(--sp-8) + var(--sp-3)) 1fr var(--sp-8) var(--sp-7);
    gap: var(--sp-5);
  }
  .thread-row__num,
  .thread-row__date,
  .thread-row__sig,
  .thread-row__agency {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .thread-row__date { color: var(--fg-mid); }
  .thread-row__sig--high { color: var(--fg); font-weight: 500; }
  .thread-row__sig--medium,
  .thread-row__sig--low { color: var(--fg-dim); }
  .thread-row__agency { text-align: right; }
  .thread-row__title {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.25;
    color: var(--fg);
  }
  .thread-row__thumb {
    display: block;
    width: var(--sp-8);
    height: var(--sp-7);
    overflow: hidden;
  }
  .thread-row__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) contrast(1.05);
    display: block;
  }
  .thread-row__link:hover .thread-row__thumb img,
  .thread-row__link:focus-visible .thread-row__thumb img {
    filter: grayscale(1) contrast(1.05) invert(1);
  }
  @media (max-width: 720px) {
    .thread-row__link {
      grid-template-columns: var(--sp-6) var(--sp-7) 1fr;
      gap: var(--sp-3);
    }
    .thread-row__date,
    .thread-row__sig,
    .thread-row__agency { display: none; }
    .thread-row__thumb { width: var(--sp-7); height: var(--sp-6); }
    .thread-row__title { font-size: 16px; }
  }

  .thread-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-5);
    margin-top: var(--sp-8);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--fg);
  }
  @media (max-width: 720px) {
    .thread-nav { grid-template-columns: 1fr; gap: var(--sp-4); }
  }
  .thread-nav__link {
    display: grid;
    gap: var(--sp-4);
    text-decoration: none;
    color: inherit;
    padding: var(--sp-4);
    margin: 0 calc(-1 * var(--sp-4));
    transition: background-color var(--dur-quick) linear,
                color var(--dur-quick) linear;
  }
  .thread-nav__link--prev {
    grid-template-columns: auto 1fr;
    text-align: left;
  }
  .thread-nav__link--next {
    grid-template-columns: 1fr auto;
    text-align: right;
  }
  .thread-nav__link:hover,
  .thread-nav__link:focus-visible {
    background: var(--fg);
    color: var(--bg);
    outline: none;
  }
  .thread-nav__link:hover .thread-nav__eyebrow,
  .thread-nav__link:focus-visible .thread-nav__eyebrow {
    color: var(--bg);
  }
  .thread-nav__arrow {
    font-family: var(--font-mono);
    font-size: 24px;
    color: var(--fg);
    align-self: center;
  }
  .thread-nav__link:hover .thread-nav__arrow,
  .thread-nav__link:focus-visible .thread-nav__arrow {
    color: var(--bg);
  }
  .thread-nav__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .thread-nav__link--next .thread-nav__body { align-items: flex-end; }
  .thread-nav__eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .thread-nav__title {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.2;
    color: inherit;
  }
</style>
