---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getAllEntities } from '../../lib/entities';
import {
  archiveOf,
  caseUrl,
  headlineDate,
  threadOf,
  tidyTitle,
} from '../../lib/case-utils';
import { entityImage } from '../../lib/case-images';

export async function getStaticPaths() {
  const all = await getAllEntities();
  return all.map((entity) => ({
    params: { slug: entity.slug },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const Content = entity.context ? (await render(entity.context)).Content : null;
const cases = entity.cases.slice().sort((a, b) => {
  const da = headlineDate(a) ?? '';
  const db = headlineDate(b) ?? '';
  return da.localeCompare(db);
});

const img = entityImage(entity.slug);
const caseCount = cases.length;

const entityDescription = `${caseCount} case${caseCount === 1 ? '' : 's'} in the archive reference ${entity.display}.`;
const collectionProps = {
  name: `${entity.display} — cases in The UFO Files`,
  description: entityDescription,
  items: cases.map((c) => ({
    name: tidyTitle(c.data.title),
    url: caseUrl(c),
    description: headlineDate(c) ?? undefined,
  })),
};
const breadcrumbProps = [
  { name: 'The UFO Files', item: '/' },
  { name: 'Entities', item: '/atlas' },
  { name: entity.display, item: `/entity/${entity.slug}` },
];
---
<Base
  title={entity.display}
  description={entityDescription}
  section={entity.display.toUpperCase()}
  ogImage={img?.src}
  collection={collectionProps}
  breadcrumbs={breadcrumbProps}
>
  <main class="entity-main" id="main">

    <a class="ufo-section-anchor entity-anchor" href="/">
      <span class="ufo-section-anchor__num">{caseCount}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Entity reference</span>
        <span class="ufo-section-anchor__sublabel">Case{caseCount === 1 ? '' : 's'} that name {entity.display}</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Open archive</span>
    </a>

    <header class="entity-hero">
      <h1 class="entity-hero__title">{entity.display}.</h1>
      <p class="entity-hero__meta">
        <a href="/timeline">Across the archive</a>
        &nbsp;/&nbsp;
        Referenced in {caseCount} case{caseCount === 1 ? '' : 's'}
      </p>
    </header>

    {img && (
      <a class="ufo-figure-link entity-hero__figure-link" href={`/dossier/${cases[0]?.id ?? ''}`} aria-label={`Open the first case that references ${entity.display}`}>
        <figure class="entity-hero__figure">
          <img src={img.src} alt={img.alt} loading="eager" fetchpriority="high" />
          <figcaption>{img.caption}</figcaption>
        </figure>
      </a>
    )}

    <div class="entity-plate">
      <article class="entity-body">
        {Content && <Content />}
        {!Content && (
          <p class="entity-body__stub">
            No standalone context page for this entity yet. Below is every case
            in the archive that names {entity.display}. The source corpus is at
            <a href="https://github.com/wretcher207/the-ufo-files" rel="noopener external">
              github.com/wretcher207/the-ufo-files</a>.
          </p>
        )}
      </article>

      <aside class="entity-rail" aria-labelledby="entity-cases-h">
        <header class="entity-rail__head">
          <h2 id="entity-cases-h" class="entity-rail__title">Where this entity appears</h2>
          <span class="entity-rail__count">{caseCount} {caseCount === 1 ? 'case' : 'cases'}</span>
        </header>
        {caseCount === 0 ? (
          <p class="entity-rail__empty">No cases reference this entity yet.</p>
        ) : (
          <ol class="entity-cases">
            {cases.map((c, i) => {
              const thread = threadOf(c);
              const sig = String(c.data.significance ?? 'medium').toLowerCase();
              return (
                <li class="entity-case">
                  <a href={caseUrl(c)} class="entity-case__link ufo-row-link">
                    <span class="entity-case__num ufo-row-link__dim">{String(i + 1).padStart(2, '0')}</span>
                    <span class="entity-case__body">
                      <span class="entity-case__title ufo-row-link__fg">{tidyTitle(c.data.title)}</span>
                      <span class="entity-case__chrome ufo-row-link__dim">
                        <span class="entity-case__archive">{archiveOf(c) === 'pursue' ? 'PURSUE' : 'FBI'}</span>
                        <span aria-hidden="true">·</span>
                        <span class="entity-case__date">{headlineDate(c) ?? '----'}</span>
                        {thread && <>
                          <span aria-hidden="true">·</span>
                          <span class="entity-case__thread">{thread.title}</span>
                        </>}
                        {sig === 'high' && <>
                          <span aria-hidden="true">·</span>
                          <span class="entity-case__sig">HEADLINE</span>
                        </>}
                      </span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ol>
        )}
      </aside>
    </div>

  </main>
</Base>

<style is:global>
  .entity-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6) var(--sp-8);
  }
  @media (max-width: 720px) {
    .entity-main { padding: var(--sp-6) var(--sp-4) var(--sp-7); }
  }

  .entity-anchor { margin-bottom: var(--sp-7); }
  @media (max-width: 720px) {
    .entity-anchor { margin-bottom: var(--sp-6); }
  }

  .entity-hero { margin: 0 0 var(--sp-6); max-width: 60ch; }
  .entity-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 var(--sp-5);
    max-width: 22ch;
  }
  .entity-hero__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0;
  }
  .entity-hero__meta a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .entity-hero__meta a:hover,
  .entity-hero__meta a:focus-visible {
    border-bottom-color: var(--fg);
  }

  .entity-hero__figure-link {
    margin: 0 0 var(--sp-7);
    max-width: 720px;
  }
  .entity-hero__figure { margin: 0; }
  .entity-hero__figure img {
    width: 100%;
    height: auto;
    max-height: 60vh;
    object-fit: contain;
    display: block;
    filter: grayscale(1) contrast(1.05);
  }

  /* Plate: prose body + cases rail. Rail width is content-sized
     (numbered list with title + chrome row) and clamped for fluid breath. */
  .entity-plate {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(280px, 30vw, 380px);
    gap: var(--sp-7);
    align-items: start;
  }
  @media (max-width: 960px) {
    .entity-plate { grid-template-columns: 1fr; gap: var(--sp-6); }
  }

  .entity-body {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.65;
    color: var(--fg);
    max-width: 64ch;
  }
  .entity-body h2, .entity-body h3 {
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--fg);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .entity-body h2 { font-size: 36px; margin: var(--sp-7) 0 var(--sp-4); }
  .entity-body h3 { font-size: 24px; margin: var(--sp-6) 0 var(--sp-3); }
  .entity-body h2:first-child, .entity-body h3:first-child { margin-top: 0; }
  .entity-body p { margin: var(--sp-3) 0 var(--sp-4); }
  .entity-body a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 4px;
  }
  .entity-body a:hover, .entity-body a:focus-visible {
    text-decoration-color: var(--fg);
  }
  .entity-body__stub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.4;
    color: var(--fg-mid);
  }

  .entity-rail__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--fg);
    margin-bottom: 0;
  }
  .entity-rail__title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg);
    margin: 0;
  }
  .entity-rail__count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .entity-rail__empty {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: var(--sp-5) 0 0;
  }

  .entity-cases { margin: 0; padding: 0; list-style: none; }
  .entity-case { border-bottom: 1px solid var(--rule); }
  .entity-case__link {
    grid-template-columns: var(--sp-6) 1fr;
    gap: var(--sp-4);
    align-items: start;
  }
  .entity-case__num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
  }
  .entity-case__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .entity-case__title {
    font-family: var(--font-display);
    font-size: 17px;
    line-height: 1.25;
  }
  .entity-case__chrome {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    display: flex;
    flex-wrap: wrap;
    gap: 0 var(--sp-2);
  }
  .entity-case__sig { color: inherit; }
</style>
