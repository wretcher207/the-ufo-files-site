---
/**
 * 404 (DARK mode). Phase 6. Voice profile. No em dashes.
 */
import Base from '../layouts/Base.astro';
const path = Astro.url?.pathname ?? '';
---
<Base
  title="Not in the archive"
  description="The requested page is not in the archive."
  section="404"
>
  <section class="nf">
    <p class="nf__eyebrow">STATUS 404 · NOT IN THE ARCHIVE</p>
    <h1 class="nf__title">This page is not in the archive.</h1>
    <p class="nf__lede">
      Either the case got renamed, you followed a stale link, or it never
      existed. Try the board, the timeline, or hit Cmd-K to search.
    </p>
    {path && (
      <p class="nf__path">Requested: <code>{path}</code></p>
    )}
    <div class="nf__actions">
      <a class="nf__btn" href="/board">Open the Board</a>
      <button class="nf__btn" type="button" data-search-trigger>Search the archive</button>
    </div>
  </section>
</Base>

<script>
  // Hook the "Search the archive" button into the ⌘K search trigger.
  document.querySelectorAll('[data-search-trigger]').forEach((el) => {
    el.addEventListener('click', () => {
      const evt = new KeyboardEvent('keydown', { key: 'k', metaKey: true, bubbles: true });
      document.dispatchEvent(evt);
    });
  });
</script>

<style>
  .nf {
    max-width: 64ch;
    margin: 0 auto;
    padding: var(--sp-9) 0;
  }
  .nf__eyebrow {
    font-family: var(--font-mono);
    font-weight: var(--weight-mono-md);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--accent-amber);
    margin: 0 0 var(--sp-5);
  }
  .nf__title {
    font-family: var(--font-display);
    font-weight: var(--weight-display);
    font-size: var(--fs-2xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--ink-primary);
    margin: 0 0 var(--sp-5);
  }
  @media (max-width: 640px) {
    .nf__title { font-size: var(--fs-xl); }
  }
  .nf__lede {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    line-height: var(--lh-loose);
    color: var(--ink-secondary);
    margin: 0 0 var(--sp-4);
  }
  .nf__path {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-muted);
    margin: 0 0 var(--sp-6);
  }
  .nf__path code {
    background: var(--bg-raised);
    padding: 2px 8px;
    border: 1px solid var(--rule);
    color: var(--ink-primary);
  }
  .nf__actions {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }
  .nf__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-weight: var(--weight-mono-md);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--accent-amber);
    background: transparent;
    text-decoration: none;
    padding: 10px var(--sp-4);
    border: 1px solid var(--accent-amber);
    border-radius: var(--radius-1);
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .nf__btn:hover {
    background: var(--accent-amber);
    color: var(--bg-base);
  }
</style>
