---
import Base from '../layouts/Base.astro';
const path = Astro.url?.pathname ?? '';
---
<Base
  title="Not found"
  description="The requested archive path does not exist."
  serial="ARCHIVE://NOT_FOUND"
  section="OFFLINE"
  status="warn"
>
  <section class="nf">
    <p class="nf__eyebrow">Status 404 · No file with this designation</p>
    <h1 class="nf__title">This corner of the archive is empty.</h1>
    <p class="nf__lede">
      The path you requested isn't indexed in the May 2026 PURSUE release or FBI 62-HQ-83894 mining pass.
      Common reasons: the case hasn't been mined yet, the entity slug isn't referenced in any case
      frontmatter, or a link is pointing at a draft path.
    </p>
    {path && <p class="nf__path">Requested: <code>{path}</code></p>}
    <div class="nf__actions">
      <a class="nf__action" href="/">Return to case board</a>
      <a class="nf__action" href="https://github.com/wretcher207/the-ufo-files" rel="noopener external" target="_blank">Search the source archive ↗</a>
    </div>
  </section>
</Base>

<style>
  .nf {
    padding: var(--sp-9) 0 var(--sp-9);
    border-top: 1px solid var(--border);
    max-width: 70ch;
  }
  .nf__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--signal-warn);
    margin: 0 0 var(--sp-5);
  }
  .nf__title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
    margin: 0 0 var(--sp-5);
    font-weight: 500;
  }
  @media (max-width: 640px) { .nf__title { font-size: var(--fs-xl); } }
  .nf__lede {
    font-family: var(--font-ui);
    font-size: var(--fs-md);
    line-height: var(--lh-loose);
    color: var(--fg-2);
    margin: 0 0 var(--sp-4);
  }
  .nf__path {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-3);
    margin: 0 0 var(--sp-6);
  }
  .nf__path code {
    background: var(--bg-2);
    padding: 2px 8px;
    border: 1px solid var(--border);
    color: var(--fg-1);
  }
  .nf__actions { display: flex; gap: var(--sp-4); flex-wrap: wrap; }
  .nf__action {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-1);
    text-decoration: none;
    padding: 8px 14px;
    border: 1px solid var(--border);
    transition: color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }
  .nf__action:hover { color: var(--crt-glow); border-color: var(--border-strong); }
</style>
