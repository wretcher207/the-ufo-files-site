---
/**
 * 404 (DARK mode). Phase 6 identity pass.
 *
 * Single block, no card. Big number for "404," small mono label
 * underneath. Two recovery actions: timeline and search trigger.
 */
import Base from '../layouts/Base.astro';
const path = Astro.url?.pathname ?? '';
---
<Base
  title="Not in the archive"
  description="The requested page is not in the archive."
  section="404"
>
  <main class="nf-main" id="main">

    <a class="ufo-section-anchor nf-anchor" href="/">
      <span class="ufo-section-anchor__num">404</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Not in the archive</span>
        <span class="ufo-section-anchor__sublabel">Status 404 &nbsp;/&nbsp; Page not found</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Open archive</span>
    </a>

    <section class="nf">
      <h1 class="nf__title">This page is not in the archive.</h1>
      <p class="nf__lede">
        Either the case got renamed, you followed a stale link, or it never
        existed. Try the timeline, read by thread, or search the corpus by
        pressing the forward slash.
      </p>
      {path && (
        <p class="nf__path">
          REQUESTED &nbsp;/&nbsp; <code>{path}</code>
        </p>
      )}

      <ul class="nf__actions">
        <li><a class="nf__action" href="/timeline">
          <span class="nf__action-icon">↗</span>
          <span>
            <span class="nf__action-title">Open the timeline</span>
            <span class="nf__action-sub">All 63 files, 1944 → 2026</span>
          </span>
        </a></li>
        <li><a class="nf__action" href="/threads">
          <span class="nf__action-icon">↗</span>
          <span>
            <span class="nf__action-title">Read by thread</span>
            <span class="nf__action-sub">Six spines through the archive</span>
          </span>
        </a></li>
        <li><button class="nf__action nf__action--btn" type="button" data-search-trigger>
          <span class="nf__action-icon">/</span>
          <span>
            <span class="nf__action-title">Search the corpus</span>
            <span class="nf__action-sub">63 pages, full-text Pagefind index</span>
          </span>
        </button></li>
      </ul>
    </section>

  </main>
</Base>

<script>
  document.querySelectorAll('[data-search-trigger]').forEach((el) => {
    el.addEventListener('click', () => {
      const evt = new KeyboardEvent('keydown', { key: '/', bubbles: true });
      document.dispatchEvent(evt);
    });
  });
</script>

<style>
  .nf-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6) var(--sp-8);
  }
  @media (max-width: 720px) {
    .nf-main { padding: var(--sp-6) var(--sp-4) var(--sp-7); }
  }

  .nf-anchor { margin-bottom: var(--sp-7); }
  @media (max-width: 720px) {
    .nf-anchor { margin-bottom: var(--sp-6); }
  }

  .nf { max-width: 64ch; }

  .nf__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 var(--sp-5);
  }
  .nf__lede {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-mid);
    margin: 0 0 var(--sp-6);
    max-width: 56ch;
  }
  .nf__path {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0 0 var(--sp-7);
    word-break: break-all;
  }
  .nf__path code {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg);
    background: transparent;
    padding: 0 var(--sp-2);
    border: 1px solid var(--rule);
  }

  .nf__actions {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--fg);
  }
  .nf__action {
    display: grid;
    grid-template-columns: var(--sp-6) 1fr;
    gap: var(--sp-5);
    align-items: center;
    width: 100%;
    padding: var(--sp-4);
    margin: 0 calc(-1 * var(--sp-4));
    text-decoration: none;
    color: inherit;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--rule);
    font: inherit;
    text-align: left;
    cursor: pointer;
    transition: background-color var(--dur-quick) linear,
                color var(--dur-quick) linear;
  }
  .nf__action:hover,
  .nf__action:focus-visible {
    background: var(--fg);
    color: var(--bg);
    outline: none;
  }
  .nf__action-icon {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--fg);
    text-align: center;
  }
  .nf__action:hover .nf__action-icon,
  .nf__action:focus-visible .nf__action-icon { color: var(--bg); }
  .nf__action-title {
    display: block;
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.2;
    color: var(--fg);
  }
  .nf__action:hover .nf__action-title,
  .nf__action:focus-visible .nf__action-title { color: var(--bg); }
  .nf__action-sub {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin-top: var(--sp-1);
  }
  .nf__action:hover .nf__action-sub,
  .nf__action:focus-visible .nf__action-sub { color: var(--bg); }
</style>
