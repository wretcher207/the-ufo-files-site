---
import Base from '../layouts/Base.astro';
import { getGraph } from '../graph/data/buildGraph';
import NetworkAtlas from '../graph/components/NetworkAtlas';
import AtlasMobile from '../graph/components/AtlasMobile';
import '../styles/atlas.css';
import '../graph/components/board.css';

const { nodes, edges } = await getGraph();
---
<Base
  title="Evidence Atlas"
  description="The full corpus rendered as a navigable WebGL network. Filter by node type, agency, confidence, date, and thread. Search any case."
  section="ATLAS"
>
  <div class="atlas-page" data-atlas-page>
    <div class="atlas-page__desktop">
      <NetworkAtlas client:only="react" nodes={nodes} edges={edges} />
    </div>
    <div class="atlas-page__mobile">
      <AtlasMobile client:only="react" nodes={nodes} edges={edges} />
    </div>

    {/* Hidden accessible mirror of the network, so keyboard and screen-reader
        users can reach every node without the WebGL canvas. */}
    <ul class="atlas-sr-mirror" aria-label="All cases in the atlas">
      {nodes.map((n) => (
        <li>
          <a href={n.collection === 'entities' ? `/entity/${n.slug}` : `/dossier/${n.slug}`}>
            <span>{n.id}</span> <span>{n.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<script>
  // The React components consume URL state via the shared graphStore inside
  // their own effects. This pre-hydration script reads the URL and writes
  // through the store BEFORE the React entry mounts, so the first render
  // already reflects deep-linked focus, type filter, and agency filter.
  import { useGraphStore } from '../graph/store/graphStore';
  import type { Confidence, EvidenceNodeType } from '../graph/types';

  function parseList(v: string | null): string[] {
    if (!v) return [];
    return v.split(',').map((s) => s.trim()).filter(Boolean);
  }

  const params = new URLSearchParams(window.location.search);
  const focus = params.get('focus');
  const types = parseList(params.get('type')) as EvidenceNodeType[];
  const agencies = parseList(params.get('agency'));
  const confidences = parseList(params.get('confidence')) as Confidence[];
  const threads = parseList(params.get('thread'));

  const store = useGraphStore.getState();
  if (focus) store.selectNode(focus);
  if (types.length) store.setFilter('nodeTypes', new Set(types));
  if (agencies.length) store.setFilter('agencies', new Set(agencies));
  if (confidences.length) store.setFilter('confidences', new Set(confidences));
  if (threads.length) store.setFilter('threads', new Set(threads));
</script>

<style>
  .atlas-page {
    position: relative;
    /* OperatorChrome is `--chrome-h` fixed; page-shell pads top by `--chrome-h`. */
    height: calc(100vh - var(--chrome-h));
    width: 100%;
    overflow: hidden;
    background: var(--bg);
  }
  .atlas-page__desktop { display: none; height: 100%; }
  .atlas-page__mobile  { display: block; height: 100%; }
  @media (min-width: 768px) {
    .atlas-page__desktop { display: block; height: 100%; }
    .atlas-page__mobile  { display: none; }
  }

  .atlas-sr-mirror {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
</style>
