---
import Base from '../layouts/Base.astro';
---
<Base
  title="Evidence Atlas"
  description="The unified research surface for The UFO Files archive. Filter, scrub, and cross-reference every case from one screen."
  serial="ATLAS/PREVIEW"
  section="EVIDENCE ATLAS"
>
  <section class="section" style="margin-top: var(--sp-7);">
    <header class="section__head">
      <div class="section__title-block">
        <span class="section__eyebrow">MOD-05 · Investigation mode</span>
        <h1 class="section__title">Evidence Atlas</h1>
      </div>
      <span class="section__meta">Building · Phase 3</span>
    </header>

    <div class="coming-soon">
      <span class="coming-soon__label">Under construction</span>
      <h2 class="coming-soon__title">The unified research surface is being built.</h2>
      <p class="coming-soon__body">
        Atlas will combine the case list, chronology, geography, and network into one screen
        with a side drawer preview. Filters across source, thread, signal, evidence type,
        media type, date range, entity, and location.
      </p>
      <p class="coming-soon__body">
        For now, enter the archive through Timeline, Map, or Graph from the top nav.
      </p>
      <div class="wake__actions" style="margin-top: var(--sp-4);">
        <a class="btn" href="/timeline">Timeline</a>
        <a class="btn" href="/map">Map</a>
        <a class="btn" href="/graph">Entity graph</a>
        <a class="btn btn--primary" href="/">Back to case board</a>
      </div>
    </div>
  </section>
</Base>
