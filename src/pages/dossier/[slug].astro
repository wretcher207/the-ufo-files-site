---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CaseActions from '../../components/CaseActions.astro';
import EntityRail from '../../components/EntityRail.astro';
import RelatedCases from '../../components/RelatedCases.astro';
import ProvenanceFooter from '../../components/ProvenanceFooter.astro';
import { archiveOf, getRenderableCases, headlineDate, threadOf, tidyTitle } from '../../lib/case-utils';
import { caseImage } from '../../lib/case-images';

export async function getStaticPaths() {
  const cases = await getRenderableCases();
  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, all: cases },
  }));
}

const { entry, all } = Astro.props;
const { Content } = await render(entry);

const archive = archiveOf(entry);
const thread = threadOf(entry);
const sectionLabel = thread?.title ?? 'Dossier';
const headline = tidyTitle(entry.data.title);
const data = entry.data;
const date = headlineDate(entry);
const caseId =
  (typeof data.caseId === 'string' && data.caseId) ||
  `${archive === 'pursue' ? 'PURSUE' : 'FBI-62HQ-83894'}/${entry.id}`;
const agency =
  (typeof data.agency === 'string' && data.agency) ||
  (typeof data.publisher === 'string' && data.publisher) ||
  (archive === 'pursue' ? 'WAR.GOV / PURSUE' : 'FBI');
const classification =
  (typeof data.classification === 'string' && data.classification) || 'PUBLIC RELEASE';
const confidence = String((data as any).confidence ?? 'low').toUpperCase();
const excerpt = (data as any).excerpt ?? (data as any).summary ?? '';

const img = caseImage(entry.id);

const pageUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;

const body: string = (entry as unknown as { body?: string }).body ?? '';
---
<Base
  title={headline}
  description={excerpt || `${caseId} — ${headline}`}
  section={sectionLabel}
  ogImage={img?.src}
>
  <article class="dossier" data-pagefind-body>

    <header class="dossier__masthead">
      <p class="dossier__eyebrow">
        {caseId}
        {date && <> &nbsp;/&nbsp; {date}</>}
        {agency && <> &nbsp;/&nbsp; {agency}</>}
      </p>
      <h1 class="dossier__title">{headline}</h1>
      {excerpt && <p class="dossier__lede">{excerpt}</p>}
      <p class="dossier__meta">
        CLASSIFICATION {classification.toUpperCase()}
        &nbsp;/&nbsp; CONFIDENCE {confidence}
        {thread && <> &nbsp;/&nbsp; <a href={`/thread/${thread.id}`}>{thread.title}</a></>}
      </p>
    </header>

    {img && (entry.data.origin_url ? (
      <a class="ufo-figure-link dossier__hero-link" href={`/evidence/${entry.id}`} aria-label="Open the source document for this case">
        <figure class="dossier__hero">
          <img src={img.src} alt={img.alt} loading="eager" fetchpriority="high" />
          <figcaption>{img.caption}</figcaption>
        </figure>
      </a>
    ) : (
      <figure class="dossier__hero">
        <img src={img.src} alt={img.alt} loading="eager" fetchpriority="high" />
        <figcaption>{img.caption}</figcaption>
      </figure>
    ))}

    <CaseActions entry={entry} pageUrl={pageUrl} body={body} />

    <div class="dossier__plate">
      <div class="dossier__body prose">
        <Content />
      </div>
      <aside class="dossier__rail" aria-label="Case context">
        <EntityRail entry={entry} />
      </aside>
    </div>

    <RelatedCases current={entry} all={all} />
    <ProvenanceFooter entry={entry} />
  </article>
</Base>

<style is:global>
  .dossier {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }
  @media (max-width: 720px) {
    .dossier { padding: 48px 16px 80px; }
  }

  /* MASTHEAD */
  .dossier__masthead { margin-bottom: 48px; max-width: 60ch; }
  .dossier__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0 0 24px;
  }
  .dossier__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 5.5vw, 80px);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 0 0 24px;
    color: var(--fg);
  }
  .dossier__lede {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.5;
    color: var(--fg-mid);
    margin: 0 0 24px;
    max-width: 56ch;
  }
  .dossier__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0;
  }
  .dossier__meta a { color: var(--fg); text-decoration: underline; text-decoration-color: var(--fg-dim); text-underline-offset: 4px; }
  .dossier__meta a:hover { text-decoration-color: var(--fg); }

  /* HERO IMAGE */
  .dossier__hero {
    margin: 0 0 56px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 40px 0;
  }
  .dossier__hero img {
    width: 100%;
    max-height: 80vh;
    height: auto;
    object-fit: contain;
    object-position: center;
    display: block;
    filter: grayscale(1) contrast(1.05);
  }
  [data-mode="light"] .dossier__hero img { filter: grayscale(1) contrast(1.05); }
  .dossier__hero figcaption {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin-top: 14px;
  }

  /* PLATE */
  .dossier__plate {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 64px;
    align-items: start;
    margin-top: 48px;
  }
  @media (max-width: 960px) {
    .dossier__plate { grid-template-columns: 1fr; gap: 40px; }
  }
  .dossier__rail {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  @media (max-width: 960px) {
    .dossier__rail { position: static; }
  }
  .dossier .prose { max-width: 64ch; }
  .dossier .redaction {
    display: inline-block;
    background: var(--fg);
    color: transparent;
    user-select: none;
    padding: 0 0.5em;
    line-height: 1.1;
  }
</style>
