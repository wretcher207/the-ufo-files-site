---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TopPlate from '../../components/TopPlate.astro';
import CaseActions from '../../components/CaseActions.astro';
import EntityRail from '../../components/EntityRail.astro';
import RelatedCases from '../../components/RelatedCases.astro';
import ProvenanceFooter from '../../components/ProvenanceFooter.astro';
import { archiveOf, getRenderableCases, threadOf, tidyTitle } from '../../lib/case-utils';

export async function getStaticPaths() {
  const cases = await getRenderableCases();
  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, all: cases },
  }));
}

const { entry, all } = Astro.props;
const { Content } = await render(entry);

const archive = archiveOf(entry);
const thread = threadOf(entry);
// `serial` not surfaced by current Base.astro props. Kept here in case
// Agent 7's Base rev re-introduces it.
const _serial = archive === 'pursue' ? 'PURSUE' : 'FBI 62-HQ-83894';
void _serial;
const sectionLabel = thread?.title.toUpperCase() ?? 'DOSSIER';
const headline = tidyTitle(entry.data.title);

// Page URL for citations + sharing.
const pageUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.pathname;

// Raw body for the export .md download. `entry.body` exists on glob loader
// entries. Type-narrowed via any-cast since the type isn't surfaced.
const body: string = (entry as unknown as { body?: string }).body ?? '';
---
<Base title={headline} section={sectionLabel}>
  <article class="dossier" data-pagefind-body>
    {/* TOP PLATE — exploded composition, 60vh. */}
    <TopPlate entry={entry} />

    {/* CASE ACTIONS — sticky horizontal bar, collapses past hero. */}
    <CaseActions entry={entry} pageUrl={pageUrl} body={body} />

    {/* READING PLATE — single column, max 68ch, with right rail on desktop. */}
    <div class="dossier__plate">
      <div class="dossier__body prose">
        <Content />
      </div>

      <aside class="dossier__rail" aria-label="Case context">
        <EntityRail entry={entry} />
      </aside>
    </div>

    <RelatedCases current={entry} all={all} />

    <ProvenanceFooter entry={entry} />
  </article>
</Base>

<style is:global>
  .dossier { display: block; }

  .dossier__plate {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 320px);
    gap: var(--sp-7);
    align-items: start;
    margin-top: var(--sp-6);
  }
  @media (max-width: 960px) {
    .dossier__plate {
      grid-template-columns: 1fr;
      gap: var(--sp-5);
    }
  }
  .dossier__rail {
    position: sticky;
    top: calc(56px + 80px);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  @media (max-width: 960px) {
    .dossier__rail { position: static; }
  }

  /* Reading plate prose, scoped to the dossier. Tightens .prose to the
     plan-spec values: max 68ch, line-height 1.7, h3 in Schibsted 600. */
  .dossier .prose { max-width: 68ch; }
  .dossier .prose h2 {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: var(--weight-display);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    margin: var(--sp-8) 0 var(--sp-4);
  }
  .dossier .prose h3 {
    font-family: var(--font-body);
    font-weight: var(--weight-body-sb);
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
    margin: var(--sp-6) 0 var(--sp-3);
  }
  .dossier .prose p {
    margin: var(--sp-3) 0 var(--sp-4);
    line-height: var(--lh-loose);
  }
  .dossier .prose blockquote {
    margin: var(--sp-5) 0;
    padding: var(--sp-2) var(--sp-5);
    border-left: 2px solid var(--accent-verdigris);
    color: var(--ink-primary);
    font-style: italic;
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
  }

  /* Inline case IDs, coordinates, dates render mono. */
  .dossier .prose code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--bg-raised);
    padding: 1px 6px;
    border: 1px solid var(--rule);
    color: var(--ink-primary);
  }

  /* Crisp solid-black redaction bar. No font trickery, no scanlines. */
  .dossier .redaction,
  .dossier .prose .redaction {
    display: inline-block;
    background: #000;
    color: transparent;
    user-select: none;
    padding: 0 0.4em;
    border-radius: 1px;
    line-height: 1;
    vertical-align: baseline;
  }
</style>
