---
import Base from '../layouts/Base.astro';
import { caseImage } from '../lib/case-images';

const LOCATIONS = [
  { slug: 'kenneth-arnold-cascade-1947',  label: 'Kenneth Arnold sighting',  lat: 46.8523,  lng: -121.7603, year: 1947, archive: 'fbi',    sig: 'high' },
  { slug: 'maury-island-1947',            label: 'Maury Island incident',    lat: 47.3650,  lng: -122.4570, year: 1947, archive: 'fbi',    sig: 'high' },
  { slug: 'rhodes-phoenix-photographs-1947', label: 'Rhodes Phoenix photographs', lat: 33.4484, lng: -112.0740, year: 1947, archive: 'fbi', sig: 'medium' },
  { slug: 'muroc-1947-cic-affidavits',    label: 'Muroc AAF affidavits',     lat: 34.9054,  lng: -117.8835, year: 1947, archive: 'fbi',    sig: 'medium' },
  { slug: 'mantell-p51-fatality-january-1948-dayton-clipping', label: 'Mantell P-51 fatality', lat: 36.6781, lng: -85.1467, year: 1948, archive: 'fbi', sig: 'high' },
  { slug: 'oak-ridge-gasser-atomic-propulsion-1947-1949', label: 'Oak Ridge installation', lat: 35.9706, lng: -84.2696, year: 1948, archive: 'fbi', sig: 'high' },
  { slug: 'guy-hottel-three-saucers-new-mexico-1950', label: 'Hottel memo (Roswell area)', lat: 33.3943, lng: -104.5230, year: 1950, archive: 'fbi', sig: 'high' },
  { slug: 'belmont-twinkle-master-memo-osi-log-1949-1950', label: 'Belmont/Twinkle OSI log', lat: 32.8517, lng: -106.1063, year: 1950, archive: 'fbi', sig: 'high' },
  { slug: 'la-paz-seventh-report-cabell-directive-twinkle', label: 'La Paz green-fireball report', lat: 34.0341, lng: -106.9056, year: 1950, archive: 'fbi', sig: 'medium' },
  { slug: 'kodiak-alaska-oni-january-1950', label: 'Kodiak ONI cable',       lat: 57.7900,  lng: -152.4072, year: 1950, archive: 'fbi', sig: 'medium' },
  { slug: 'pervier-tulsa-fbi-agent-corroboration-1950', label: 'Pervier Tulsa case', lat: 36.1540, lng: -95.9928, year: 1950, archive: 'fbi', sig: 'medium' },
  { slug: 'phoenix-blythe-radar-intercept-509th-bomb-group-june-1950', label: '509th Bomb Group radar intercept', lat: 33.6105, lng: -114.5963, year: 1950, archive: 'fbi', sig: 'medium' },
  { slug: 'philadelphia-1950-soap-suds-disc', label: 'Philadelphia soap suds disc', lat: 39.9526, lng: -75.1652, year: 1950, archive: 'fbi', sig: 'medium' },
  { slug: 'james-collins-chesapeake-abduction-january-1967', label: 'Chesapeake abduction', lat: 36.7682, lng: -76.2875, year: 1967, archive: 'fbi', sig: 'medium' },
  { slug: 'mexico-2003-alien-corpses',    label: 'Mexico congress cable',    lat: 19.4326,  lng: -99.1332,  year: 2003, archive: 'pursue', sig: 'medium' },
  { slug: 'kazakhstan-1994-747',          label: 'Kazakhstan 747 cable',     lat: 51.1605,  lng: 71.4704,   year: 1994, archive: 'pursue', sig: 'medium' },
  { slug: 'usper-statement',              label: 'USPER orb chase',          lat: 38.8951,  lng: -77.0364,  year: 2025, archive: 'pursue', sig: 'high' },
  { slug: 'orbs-launching-orbs',          label: 'Western US orbs cluster',  lat: 40.7608,  lng: -111.8910, year: 2023, archive: 'pursue', sig: 'high' },
  { slug: 'bronze-ellipsoid',             label: 'Bronze Ellipsoid',         lat: 37.2350,  lng: -115.8111, year: 2023, archive: 'pursue', sig: 'high' },
];

const geocoded = LOCATIONS.length;
const sortedLocations = [...LOCATIONS].sort((a, b) => a.year - b.year);
---
<Base
  title="Map"
  description="Geographic distribution of headline cases."
  section="WORLD VIEW"
>
  <main class="mp-main" id="main">

    <a class="ufo-section-anchor mp-anchor" href="/timeline">
      <span class="ufo-section-anchor__num">{geocoded}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Located cases</span>
        <span class="ufo-section-anchor__sublabel">Headline incidents we could responsibly place</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Timeline</span>
    </a>

    <header class="mp-hero">
      <h1 class="mp-hero__title">Where the file went down.</h1>
      <p class="mp-hero__lede">
        Every high-signal case from FBI 62-HQ-83894 and PURSUE Release 01 with a
        location we could responsibly place. Memo correspondence and policy
        cases stay off the map. See the
        <a href="/timeline">timeline</a> for the complete sequence.
      </p>
    </header>

    <div id="ufo-map" class="mp-map" role="region" aria-label="Map of cases">
      <div class="mp-map__fallback">
        <p>Map view requires JavaScript. The cases below are the full geocoded set.</p>
      </div>
    </div>

    <section class="mp-list" aria-labelledby="mp-list-h">
      <header class="mp-list__head">
        <h2 id="mp-list-h" class="mp-list__title">Located cases &nbsp;/&nbsp; chronological</h2>
        <span class="mp-list__count">{geocoded}</span>
      </header>
      <ol class="mp-locations">
        {sortedLocations.map((loc, i) => {
          const img = caseImage(loc.slug);
          return (
            <li class="mp-location">
              <a href={'/dossier/' + loc.slug} class="mp-location__link ufo-row-link">
                <span class="mp-location__num ufo-row-link__dim">{String(i + 1).padStart(2, '0')}</span>
                <span class="mp-location__thumb">
                  {img && <img src={img.src} alt="" width="80" height="56" loading="lazy" />}
                </span>
                <span class="mp-location__year ufo-row-link__mid">{loc.year}</span>
                <span class="mp-location__title ufo-row-link__fg">{loc.label}</span>
                <span class={'mp-location__sig mp-location__sig--' + loc.sig + ' ufo-row-link__dim'}>
                  {loc.sig === 'high' ? 'HEADLINE' : 'MEDIUM'}
                </span>
                <span class="mp-location__agency ufo-row-link__dim">
                  {loc.archive === 'pursue' ? 'PURSUE' : 'FBI'}
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    </section>

  </main>
</Base>

<style>
  .mp-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-6) var(--sp-8);
  }
  @media (max-width: 720px) {
    .mp-main { padding: var(--sp-6) var(--sp-4) var(--sp-7); }
  }

  .mp-anchor { margin-bottom: var(--sp-7); }
  @media (max-width: 720px) {
    .mp-anchor { margin-bottom: var(--sp-6); }
  }

  .mp-hero { max-width: 70ch; margin: 0 0 var(--sp-7); }
  .mp-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 var(--sp-5);
    max-width: 22ch;
  }
  .mp-hero__lede {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-mid);
    margin: 0;
  }
  .mp-hero__lede a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 4px;
  }
  .mp-hero__lede a:hover, .mp-hero__lede a:focus-visible {
    text-decoration-color: var(--fg);
  }

  .mp-map {
    width: 100%;
    height: clamp(400px, 60vh, 640px);
    background: var(--bg);
    border-top: 1px solid var(--fg);
    border-bottom: 1px solid var(--fg);
    position: relative;
    margin-bottom: var(--sp-7);
  }
  .mp-map__fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    color: var(--fg-dim);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: var(--sp-5);
    text-align: center;
    pointer-events: none;
  }
  .mp-map.is-live .mp-map__fallback { display: none; }

  .mp-list { margin: 0 0 var(--sp-6); }
  .mp-list__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--fg);
    margin-bottom: 0;
  }
  .mp-list__title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg);
    margin: 0;
  }
  .mp-list__count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-dim);
    font-feature-settings: "tnum";
  }
  .mp-locations { margin: 0; padding: 0; list-style: none; }
  .mp-location { border-bottom: 1px solid var(--rule); }
  .mp-location__link {
    grid-template-columns: var(--sp-6) var(--sp-8) calc(var(--sp-7) + var(--sp-4)) 1fr var(--sp-8) var(--sp-7);
    gap: var(--sp-5);
    align-items: center;
  }
  .mp-location__num,
  .mp-location__year,
  .mp-location__sig,
  .mp-location__agency {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .mp-location__agency { text-align: right; }
  .mp-location__title {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.25;
  }
  .mp-location__thumb {
    display: block;
    width: var(--sp-8);
    height: var(--sp-7);
    overflow: hidden;
  }
  .mp-location__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }
  .mp-location__link:hover .mp-location__thumb img,
  .mp-location__link:focus-visible .mp-location__thumb img {
    filter: grayscale(1) contrast(1.05) invert(1);
  }
  @media (max-width: 720px) {
    .mp-location__link {
      grid-template-columns: var(--sp-6) var(--sp-7) 1fr;
      gap: var(--sp-3);
    }
    .mp-location__year,
    .mp-location__sig,
    .mp-location__agency { display: none; }
    .mp-location__thumb { width: var(--sp-7); height: var(--sp-6); }
    .mp-location__title { font-size: 15px; }
  }

  /* MapLibre popup overrides for monochrome system */
  :global(.maplibregl-popup-content) {
    background: var(--bg) !important;
    color: var(--fg) !important;
    border: 1px solid var(--fg) !important;
    border-radius: 0 !important;
    padding: 0 !important;
    box-shadow: none !important;
    font-family: var(--font-mono) !important;
  }
  :global(.maplibregl-popup-tip) { display: none !important; }
  :global(.maplibregl-ctrl-group) {
    background: var(--bg) !important;
    border: 1px solid var(--fg) !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }
  :global(.maplibregl-ctrl-group button) {
    color: var(--fg) !important;
    background: transparent !important;
  }
  :global(.maplibregl-ctrl-group button:hover) {
    background: var(--fg) !important;
    color: var(--bg) !important;
  }
  :global(.maplibregl-ctrl-group button + button) {
    border-top: 1px solid var(--rule) !important;
  }
  :global(.maplibregl-ctrl-attrib) {
    background: rgba(0,0,0,0.6) !important;
    color: var(--fg-dim) !important;
    font-family: var(--font-mono) !important;
    font-size: 9px !important;
    letter-spacing: 0.1em !important;
  }
  :global(.maplibregl-ctrl-attrib a) { color: var(--fg-mid) !important; }
</style>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" />
<script id="mp-data" type="application/json" set:html={JSON.stringify(LOCATIONS)}></script>
<script is:inline src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
<script is:inline>
  const dataEl = document.getElementById("mp-data");
  const locations = dataEl ? JSON.parse(dataEl.textContent) : [];
  const container = document.getElementById("ufo-map");
  if (container && locations.length) {
    const map = new maplibregl.Map({
      container: "ufo-map",
      style: {
        version: 8,
        sources: {
          carto: {
            type: "raster",
            tiles: [
              "https://a.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}.png",
              "https://b.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}.png",
              "https://c.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}.png",
              "https://d.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}.png",
            ],
            tileSize: 256,
            minzoom: 0,
            maxzoom: 19,
            attribution: "© OpenStreetMap contributors © CARTO",
          },
        },
        layers: [
          { id: "bg", type: "background", paint: { "background-color": "#000000" } },
          { id: "carto", type: "raster", source: "carto", paint: { "raster-saturation": -1, "raster-brightness-min": 0.05, "raster-brightness-max": 0.7, "raster-contrast": 0.2 } },
        ],
      },
      center: [-95, 40],
      zoom: 2.2,
    });
    const lats = locations.map((l) => l.lat);
    const lngs = locations.map((l) => l.lng);
    const bounds = [[Math.min(...lngs), Math.min(...lats)], [Math.max(...lngs), Math.max(...lats)]];
    map.on('load', () => {
      map.resize();
      map.fitBounds(bounds, { padding: { top: 60, bottom: 60, left: 60, right: 60 }, duration: 0, maxZoom: 4 });
    });
    requestAnimationFrame(() => map.resize());
    window.addEventListener('resize', () => map.resize());
    container.classList.add("is-live");
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), "top-right");
    for (const loc of locations) {
      const el = document.createElement("div");
      const dim = loc.sig === "high" ? 14 : 10;
      el.style.width = dim + "px";
      el.style.height = dim + "px";
      el.style.cursor = "pointer";
      el.style.outline = "1px solid #ffffff";
      el.style.outlineOffset = "0";
      el.style.transition = "background-color 90ms linear, outline-width 90ms linear";
      el.setAttribute("role", "button");
      el.setAttribute("tabindex", "0");
      el.setAttribute("aria-label", loc.label + ", " + loc.year + ", " + (loc.archive === "pursue" ? "PURSUE" : "FBI") + ". Press Enter to open dossier.");
      el.addEventListener("keydown", (ev) => {
        if (ev.key === "Enter" || ev.key === " ") {
          ev.preventDefault();
          window.location.href = "/dossier/" + loc.slug;
        }
      });
      // PURSUE = outlined empty dot, FBI = filled white dot.
      if (loc.archive === "pursue") {
        el.style.background = "#000000";
      } else {
        el.style.background = "#ffffff";
      }
      el.addEventListener("mouseenter", () => {
        el.style.background = "#ffffff";
        el.style.outline = "2px solid #ffffff";
      });
      el.addEventListener("mouseleave", () => {
        el.style.background = loc.archive === "pursue" ? "#000000" : "#ffffff";
        el.style.outline = "1px solid #ffffff";
      });
      const popup = new maplibregl.Popup({ offset: 14, closeButton: false, className: "ufo-popup" }).setHTML(
        '<div style="padding:12px 14px;font-family:inherit;font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#ffffff;min-width:200px;">' +
          '<div style="color:#888;margin-bottom:6px;">' + loc.year + ' &middot; ' + (loc.archive === 'pursue' ? 'PURSUE' : 'FBI') + (loc.sig === 'high' ? ' &middot; HEADLINE' : '') + '</div>' +
          '<div style="font-family:Fraunces,serif;font-size:15px;letter-spacing:-0.01em;text-transform:none;line-height:1.25;color:#fff;margin-bottom:10px;">' + loc.label + '</div>' +
          '<a style="color:#fff;text-decoration:underline;text-underline-offset:3px;" href="/dossier/' + loc.slug + '">Open dossier &rarr;</a>' +
        '</div>'
      );
      new maplibregl.Marker({ element: el }).setLngLat([loc.lng, loc.lat]).setPopup(popup).addTo(map);
    }
  }
</script>
