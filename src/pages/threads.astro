---
import Base from '../layouts/Base.astro';
import { THREADS } from '../lib/threads';
import { countCasesByThread, getRenderableCases } from '../lib/case-utils';

const cases = await getRenderableCases();
const countByThread = countCasesByThread(cases);

const numberWord = (n: number): string => {
  const words = ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine'];
  return words[n] ?? String(n);
};
const threadCountWord = numberWord(THREADS.length);

const collectionProps = {
  name: 'Threads — The UFO Files',
  description: 'Six narrative threads that run through the archive.',
  items: THREADS.map((t) => ({
    name: t.title,
    url: `/thread/${t.id}`,
    description: t.blurb,
  })),
};
const breadcrumbProps = [
  { name: 'The UFO Files', item: '/' },
  { name: 'Threads', item: '/threads' },
];
---
<Base
  title="Threads"
  pathname="/threads"
  description="Six narrative threads that run through The UFO Files archive."
  collection={collectionProps}
  breadcrumbs={breadcrumbProps}
>
  <main class="threads-main" id="main">

    <a class="ufo-section-anchor threads-anchor" href="/timeline">
      <span class="ufo-section-anchor__num">{String(THREADS.length).padStart(2, '0')}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Threads</span>
        <span class="ufo-section-anchor__sublabel">Six spines through the archive</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Full timeline</span>
    </a>

    <header class="threads-head">
      <h1 class="threads-title">{threadCountWord.charAt(0).toUpperCase() + threadCountWord.slice(1)} threads run through the archive.</h1>
      <p class="threads-lede">
        The files belong to one of these. Pick one and read straight through, or
        pick a single case and let the threads pull you sideways.
      </p>
    </header>

    <ol class="thread-list">
      {THREADS.map((t, i) => (
        <li class="thread-row">
          <a href={`/thread/${t.id}`} class="thread-row__link ufo-row-link">
            <span class="thread-row__num ufo-row-link__dim">{String(i + 1).padStart(2, '0')}</span>
            <span class="thread-row__body">
              <span class="thread-row__title ufo-row-link__fg">{t.title}</span>
              <span class="thread-row__span ufo-row-link__dim">{t.span}</span>
              <span class="thread-row__blurb ufo-row-link__mid">{t.blurb}</span>
            </span>
            <span class="thread-row__count">
              <span class="thread-row__count-num ufo-row-link__fg">{countByThread.get(t.id) ?? 0}</span>
              <span class="thread-row__count-label ufo-row-link__dim">cases</span>
            </span>
          </a>
        </li>
      ))}
    </ol>

  </main>
</Base>

<style>
  .threads-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }
  @media (max-width: 720px) {
    .threads-main { padding: 48px 16px 80px; }
  }

  .threads-anchor { margin-bottom: 56px; }
  @media (max-width: 720px) {
    .threads-anchor { margin-bottom: 40px; }
  }

  .threads-head { margin-bottom: 64px; }
  .threads-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(40px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 24px;
    max-width: 18ch;
  }
  .threads-lede {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.5;
    color: var(--fg-mid);
    max-width: 52ch;
    margin: 0;
  }

  .thread-list { margin: 0; padding: 0; list-style: none; }
  .thread-row { border-top: 1px solid var(--rule); }
  .thread-row:last-child { border-bottom: 1px solid var(--rule); }
  .thread-row__link {
    grid-template-columns: 56px 1fr 90px;
    gap: 24px;
    align-items: baseline;
  }
  .thread-row__num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
  }
  .thread-row__body { display: flex; flex-direction: column; gap: 6px; }
  .thread-row__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .thread-row__span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .thread-row__blurb {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    max-width: 70ch;
  }
  .thread-row__count {
    text-align: right;
    font-feature-settings: "tnum";
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }
  .thread-row__count-num {
    font-family: var(--font-mono);
    font-size: 24px;
    line-height: 1;
  }
  .thread-row__count-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  @media (max-width: 720px) {
    .thread-row__link {
      grid-template-columns: 36px 1fr;
      gap: 12px;
    }
    .thread-row__count { display: none; }
    .thread-row__title { font-size: 18px; }
  }
</style>
