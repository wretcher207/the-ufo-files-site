---
/**
 * Homepage (DARK mode, single scroll). Phase 6.
 *
 * Sections:
 *   1. Hero (100vh): exploded-document composition over an anchor case
 *      rotated weekly. Two amber buttons.
 *   2. The Index: 3 entry panels.
 *   3. On the Board: live React Flow preview, ~12 nodes.
 *   4. About the Archivist: 80-word blurb + name + socials strip.
 */
import Base from '../layouts/Base.astro';
import Hero, { type SatelliteCard } from '../components/Hero.astro';
import SocialsStrip from '../components/SocialsStrip.astro';
import { HomeBoardPreview } from '../components/HomeBoardPreview';
import { THREADS } from '../lib/threads';
import {
  archiveOf,
  getAllCases,
  getRenderableCases,
  headlineDate,
  tidyTitle,
} from '../lib/case-utils';
import { getGraph } from '../graph/data/buildGraph';
import { pickWeeklyAnchor } from '../components/HeroComposition';

// All cases for counts + finding the first FBI case slug for the secondary button.
const allCases = await getAllCases();
const renderable = await getRenderableCases();
const fbiCases = renderable.filter((c) => archiveOf(c) === 'fbi');
const pursueCases = renderable.filter((c) => archiveOf(c) === 'pursue');
const firstFbiSlug = fbiCases[0]?.id ?? renderable[0]?.id ?? '';

// Anchor cases for the hero rotation (one per week, deterministic).
const anchorSlugs = [
  'apollo-17-vm6',
  'bronze-ellipsoid',
  'orbs-launching-orbs',
  'usper-statement',
  'guy-hottel-three-saucers-new-mexico-1950',
];
const anchorCases = anchorSlugs
  .map((slug) => allCases.find((c) => c.id === slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c));
const heroAnchor = pickWeeklyAnchor(anchorCases) ?? anchorCases[0] ?? renderable[0];

// Build hero satellites from the anchor's frontmatter.
function buildHeroSatellites(c: typeof heroAnchor): SatelliteCard[] {
  if (!c) return [];
  const data = c.data;
  const sats: SatelliteCard[] = [];
  const heroAsset = (data as { heroAsset?: { type?: string; src?: string; alt?: string; credit?: string } }).heroAsset;
  if (heroAsset && (heroAsset.type === 'photo' || heroAsset.type === 'scan' || heroAsset.type === 'map')) {
    sats.push({
      kind: heroAsset.type,
      eyebrow: heroAsset.type.toUpperCase(),
      title: heroAsset.alt ?? `${heroAsset.type} record`,
      meta: heroAsset.credit ?? undefined,
      src: heroAsset.src ?? undefined,
      alt: heroAsset.alt ?? undefined,
    });
  }
  const witnesses = (data as { witnesses?: string[] }).witnesses;
  if (Array.isArray(witnesses) && witnesses.length > 0) {
    sats.push({
      kind: 'witness',
      eyebrow: 'WITNESS',
      title: String(witnesses[0]),
      meta: witnesses.length > 1 ? `+${witnesses.length - 1} more in file` : undefined,
    });
  }
  const agency = typeof (data as { agency?: unknown }).agency === 'string'
    ? (data as { agency: string }).agency
    : typeof data.publisher === 'string'
      ? data.publisher
      : archiveOf(c) === 'pursue' ? 'WAR.GOV / PURSUE' : 'FBI';
  const classification = typeof (data as { classification?: unknown }).classification === 'string'
    ? (data as { classification: string }).classification
    : 'PUBLIC RELEASE';
  sats.push({
    kind: 'agency',
    eyebrow: 'AGENCY STAMP',
    title: agency,
    meta: classification,
  });
  const summary = typeof (data as { summary?: unknown }).summary === 'string'
    ? (data as { summary: string }).summary
    : null;
  if (summary) {
    sats.push({
      kind: 'evidence',
      eyebrow: 'EVIDENCE',
      title: summary.length > 140 ? summary.slice(0, 137) + '…' : summary,
    });
  }
  const geo = (data as { geo?: { lat?: number; lng?: number; placeName?: string } }).geo;
  if (geo) {
    sats.push({
      kind: 'sighting',
      eyebrow: 'SIGHTING',
      title: geo.placeName ?? 'Reported location',
      meta: geo.lat != null && geo.lng != null ? `${geo.lat.toFixed(3)}, ${geo.lng.toFixed(3)}` : undefined,
    });
  }
  return sats.slice(0, 5);
}

const heroSatellites = heroAnchor ? buildHeroSatellites(heroAnchor) : [];
const heroEyebrow = heroAnchor
  ? [
      typeof heroAnchor.data.caseId === 'string' && heroAnchor.data.caseId,
      headlineDate(heroAnchor),
    ].filter(Boolean).join(' · ')
  : 'THE UFO FILES';
const heroTitle = heroAnchor ? tidyTitle(heroAnchor.data.title) : 'The UFO Files';
const heroCaseId = heroAnchor
  ? (typeof heroAnchor.data.caseId === 'string' ? heroAnchor.data.caseId : heroAnchor.id)
  : 'home';

// Archive button: open the first FBI case dossier (or fallback to timeline).
const archiveHref = firstFbiSlug ? `/dossier/${firstFbiSlug}` : '/timeline';

// PURSUE countdown / now-live state.
// The release was 2026-05-08 00:00:00 -04:00. Compute relative to BUILD time.
const PURSUE_RELEASE_ISO = '2026-05-08T00:00:00-04:00';
const releaseMs = Date.parse(PURSUE_RELEASE_ISO);
const nowMs = Date.now();
const pursueLive = nowMs >= releaseMs;
const daysToRelease = Math.max(0, Math.ceil((releaseMs - nowMs) / 86_400_000));
const pursueCount = pursueCases.length;
const fbiCount = fbiCases.length;

// Curated 12-node board subset.
// 5 PURSUE + 5 FBI + 2 entities, chosen for narrative density. Edges come
// from frontmatter relationships[]; the extraction pipeline populates those.
const BOARD_SUBSET_IDS = new Set<string>([
  // PURSUE
  'PURSUE-01/apollo-17-vm6',
  'PURSUE-01/bronze-ellipsoid',
  'PURSUE-01/orbs-launching-orbs',
  'PURSUE-01/usper-statement',
  'PURSUE-01/kazakhstan-1994-747',
  // FBI
  'FBI-62HQ-83894/kenneth-arnold-cascade-1947',
  'FBI-62HQ-83894/mantell-p51-fatality-january-1948-dayton-clipping',
  'FBI-62HQ-83894/guy-hottel-three-saucers-new-mexico-1950',
  'FBI-62HQ-83894/oak-ridge-gasser-atomic-propulsion-1947-1949',
  'FBI-62HQ-83894/maury-island-1947',
  // Entities
  'ENTITY/aaro',
  'ENTITY/pursue-program',
]);
const fullGraph = await getGraph();
const boardSubset = {
  nodes: fullGraph.nodes.filter((n) => BOARD_SUBSET_IDS.has(n.id)),
  edges: fullGraph.edges.filter(
    (e) => BOARD_SUBSET_IDS.has(e.source) && BOARD_SUBSET_IDS.has(e.target)
  ),
};
const boardNodeCount = boardSubset.nodes.length;
---
<Base
  title="The UFO Files"
  description="An archive of FBI 62-HQ-83894, the May 8 2026 PURSUE release, and the witnesses, agencies, and contradictions threaded through both."
  section="ARCHIVE"
>
  {/* ────────────────────────────── HERO ────────────────────────────── */}
  <section class="home-hero" aria-labelledby="home-hero-title">
    <div class="home-hero__stage">
      {heroAnchor && heroSatellites.length > 0 ? (
        <Hero
          centerEyebrow={heroEyebrow}
          centerTitle={heroTitle}
          satellites={heroSatellites}
          caseId={heroCaseId}
          mode="parallax"
        />
      ) : (
        <div class="home-hero__fallback">
          <span class="home-hero__eyebrow" id="home-hero-eyebrow">THE UFO FILES</span>
          <h1 class="home-hero__title" id="home-hero-title">The Unsealed Archive</h1>
        </div>
      )}
    </div>

    <div class="home-hero__plate">
      <p class="home-hero__lede">
        An archive of FBI 62-HQ-83894, the May 8 2026 PURSUE release, and the
        witnesses, agencies, and contradictions threaded through both.
      </p>
      <div class="home-hero__actions">
        <a class="btn btn--primary" href="/board">
          Open the Board
          <span class="btn__chevron" aria-hidden="true">→</span>
        </a>
        <a class="btn" href={archiveHref}>
          Browse the Archive
        </a>
        <button class="home-hero__tilt" type="button" data-tilt-toggle aria-pressed="false">
          Enable tilt
        </button>
      </div>
    </div>
  </section>

  {/* ───────────────────────────── INDEX ───────────────────────────── */}
  <section class="home-index" aria-labelledby="home-index-title">
    <header class="home-index__head">
      <span class="home-index__eyebrow">THE INDEX</span>
      <h2 id="home-index-title" class="home-index__title">Three doors into the file.</h2>
    </header>

    <div class="home-index__grid">
      <article class="home-panel home-panel--pursue">
        <span class="home-panel__eyebrow">PURSUE · LATEST RELEASE</span>
        {pursueLive ? (
          <>
            <p class="home-panel__date">MAY 8, 2026</p>
            <p class="home-panel__line">Now live.</p>
            <p class="home-panel__body">
              {pursueCount} {pursueCount === 1 ? 'case' : 'cases'} pulled from
              the Department of War tranche. Apollo 17 VM6. Bronze Ellipsoid.
              Orbs-launching-orbs. USPER. The file is open.
            </p>
            <a class="home-panel__cta" href="/dossier/apollo-17-vm6">
              Open the release →
            </a>
          </>
        ) : (
          <>
            <p class="home-panel__date">MAY 8, 2026 · 00:00 EDT</p>
            <p class="home-panel__count" data-pursue-countdown>
              T-minus {daysToRelease} {daysToRelease === 1 ? 'day' : 'days'}
            </p>
            <p class="home-panel__body">
              The Department of War's PURSUE tranche is unsealed on May 8.
              The site cuts straight to the four cases that matter.
            </p>
            <span class="home-panel__cta is-disabled" aria-disabled="true">
              Pending release
            </span>
          </>
        )}
      </article>

      <article class="home-panel">
        <span class="home-panel__eyebrow">FBI 62-HQ-83894 · CORE</span>
        <p class="home-panel__count">{fbiCount} cases</p>
        <p class="home-panel__body">
          Flying-discs case file, 1944 through 1973. Kenneth Arnold's Cascade
          sighting. Mantell. The Hottel memo read against itself. Project
          Twinkle. Civilian correspondence after Blue Book.
        </p>
        <a class="home-panel__cta" href={archiveHref}>
          Open the file →
        </a>
      </article>

      <article class="home-panel">
        <span class="home-panel__eyebrow">THREADS · FIVE DRAWERS</span>
        <ol class="home-threads">
          {THREADS.map((thread, i) => (
            <li class="home-threads__row">
              <span class="home-threads__num">{String(i + 1).padStart(2, '0')}</span>
              <a class="home-threads__link" href={`/thread/${thread.id}`}>
                <span class="home-threads__title">{thread.title}</span>
                <span class="home-threads__span">{thread.span}</span>
              </a>
            </li>
          ))}
        </ol>
      </article>
    </div>
  </section>

  {/* ──────────────────────────── ON THE BOARD ────────────────────────────── */}
  <section class="home-board" aria-labelledby="home-board-title">
    <header class="home-board__head">
      <div>
        <span class="home-board__eyebrow">ON THE BOARD</span>
        <h2 id="home-board-title" class="home-board__title">
          A starter investigation. Live.
        </h2>
        <p class="home-board__lede">
          {boardNodeCount} nodes pulled from the corpus. PURSUE anchors, FBI
          serial documents, the agencies threading them. Click any node to
          open the full board with it centered.
        </p>
      </div>
      <a class="btn" href="/board">
        Open the Board <span aria-hidden="true">→</span>
      </a>
    </header>

    <div class="home-board__embed">
      {/*
        HomeBoardPreview wraps InvestigationBoard with a thin store
        subscriber that routes node clicks to /board?focus=<id>.
      */}
      <HomeBoardPreview client:only="react" graph={boardSubset} />
    </div>

    {/* Accessible mirror of the curated subset. */}
    <ul class="sr-only" aria-label="Cases on the homepage board preview">
      {boardSubset.nodes.map((n) => (
        <li>
          <a href={n.collection === 'entities' ? `/entity/${n.slug}` : `/dossier/${n.slug}`}>
            {n.id}: {n.title}
          </a>
        </li>
      ))}
    </ul>
  </section>

  {/* ─────────────────────── ABOUT THE ARCHIVIST ─────────────────────── */}
  <section class="home-about" aria-labelledby="home-about-title">
    <header class="home-about__head">
      <span class="home-about__eyebrow">ABOUT THE ARCHIVIST</span>
      <h2 id="home-about-title" class="home-about__title">Who built this.</h2>
    </header>

    <div class="home-about__body">
      <p>
        I was eight years old when I first heard Roswell. Thirty years later
        the government published the file and I read it cover to cover. There
        are cases in there that nobody on cable news got to. There are
        cases that contradict each other. There is one photo from the lunar
        surface that nobody has cleanly explained. This archive puts every
        page in one place so a stranger can land at the start, follow the
        files, and decide for themselves.
      </p>

      <p class="home-about__name">David Russell</p>
      <p class="home-about__role">Archivist · Dead Pixel Design · Houlton, Maine</p>

      <SocialsStrip align="center" />
    </div>
  </section>
</Base>

<script>
  // PURSUE countdown updater. Only runs if a [data-pursue-countdown] is in
  // the DOM (i.e. pre-release state). Updates once per minute. Respects
  // reduced motion (no animation, just text replacement at interval).
  (() => {
    if (typeof window === 'undefined') return;
    const el = document.querySelector<HTMLElement>('[data-pursue-countdown]');
    if (!el) return;
    const releaseMs = Date.parse('2026-05-08T00:00:00-04:00');
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function update() {
      const now = Date.now();
      const diff = releaseMs - now;
      if (diff <= 0) {
        // Reload to swap into the "now live" state on next visit.
        return;
      }
      const days = Math.max(0, Math.ceil(diff / 86_400_000));
      if (el) el.textContent = `T-minus ${days} ${days === 1 ? 'day' : 'days'}`;
    }
    update();
    if (!reduced) {
      setInterval(update, 60_000);
    }
  })();
</script>

<script>
  // Tilt toggle for mobile (gyroscope). Desktop parallax is handled
  // inside Hero.astro automatically. Reduced motion disables both.
  (() => {
    if (typeof window === 'undefined') return;
    const btn = document.querySelector<HTMLButtonElement>('[data-tilt-toggle]');
    if (!btn) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) {
      btn.setAttribute('hidden', '');
      return;
    }
    // Only show on coarse-pointer (touch) devices that support gyro.
    const coarse = window.matchMedia('(pointer: coarse)').matches;
    const hasGyro = typeof (window as unknown as { DeviceOrientationEvent?: unknown }).DeviceOrientationEvent !== 'undefined';
    if (!coarse || !hasGyro) {
      btn.setAttribute('hidden', '');
      return;
    }
    let active = false;
    const stage = document.querySelector<HTMLElement>('.hero[data-mode="parallax"] .hero__stage');
    function onTilt(e: DeviceOrientationEvent) {
      if (!stage) return;
      const x = (e.gamma ?? 0) / 45;
      const y = (e.beta ?? 0) / 45;
      stage.querySelectorAll<HTMLElement>('[data-parallax-depth]').forEach((el) => {
        const depth = Number(el.dataset.parallaxDepth || '0');
        const max = 8;
        const dx = -x * depth * (max / 3);
        const dy = -y * depth * (max / 3);
        if (el.classList.contains('hero__sat')) {
          const rot = el.style.getPropertyValue('--rot') || '0deg';
          el.style.transform = `translate(${dx}px, ${dy}px) rotate(${rot})`;
        } else {
          el.style.transform = `translate(calc(-50% + ${dx}px), calc(-50% + ${dy}px))`;
        }
      });
    }
    async function enable() {
      type Req = { requestPermission?: () => Promise<'granted' | 'denied'> };
      const Constructor = (window as unknown as { DeviceOrientationEvent: Req }).DeviceOrientationEvent;
      if (Constructor && typeof Constructor.requestPermission === 'function') {
        try {
          const state = await Constructor.requestPermission();
          if (state !== 'granted') return;
        } catch {
          return;
        }
      }
      window.addEventListener('deviceorientation', onTilt);
      active = true;
      btn?.setAttribute('aria-pressed', 'true');
      btn!.textContent = 'Tilt on';
    }
    function disable() {
      window.removeEventListener('deviceorientation', onTilt);
      active = false;
      btn?.setAttribute('aria-pressed', 'false');
      btn!.textContent = 'Enable tilt';
    }
    btn.addEventListener('click', () => {
      if (active) disable();
      else enable();
    });
  })();
</script>

