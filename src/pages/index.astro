---
import Base from '../layouts/Base.astro';
import {
  archiveOf,
  countCasesByThread,
  getRenderableCases,
  headlineDate,
  tidyTitle,
} from '../lib/case-utils';
import { THREADS } from '../lib/threads';
import { caseImage } from '../lib/case-images';
import { getArchiveStats } from '../lib/archive-stats';

const renderable = await getRenderableCases();
const stats = await getArchiveStats();

function caseDate(c: typeof renderable[number]) {
  const d = headlineDate(c);
  return d ? String(d) : '';
}
function dateKey(c: typeof renderable[number]) {
  const d = caseDate(c);
  const m = d.match(/(\d{4})(?:-(\d{1,2}))?(?:-(\d{1,2}))?/);
  if (!m) return 0;
  return parseInt(m[1], 10) * 10000 + (m[2] ? parseInt(m[2], 10) * 100 : 0) + (m[3] ? parseInt(m[3], 10) : 0);
}

// Latest entries: just by date, most recent first.
const latest = [...renderable].sort((a, b) => dateKey(b) - dateKey(a)).slice(0, 18);

// Featured case for the pull. Kenneth Arnold's Cascade narrative,
// the case that started the public record.
const featured = renderable.find((c) => c.id === 'kenneth-arnold-sighting-narrative-cascade-june-1947')
  ?? renderable.find((c) => c.id === 'guy-hottel-three-saucers-new-mexico-1950')
  ?? renderable[0];

const countByThread = countCasesByThread(renderable);

// Specific dossier slugs for hero figures (linked from homepage).
const HOTTEL_SLUG = 'guy-hottel-three-saucers-new-mexico-1950';
const ARNOLD_SLUG = featured?.id ?? 'kenneth-arnold-sighting-narrative-cascade-june-1947';
const APOLLO_SLUG = 'apollo-17-vm6';
const hasApollo = renderable.some((c) => c.id === APOLLO_SLUG);
const hasHottel = renderable.some((c) => c.id === HOTTEL_SLUG);
---
<Base title="The UFO Files">

  <section class="masthead">
    <div class="masthead__grid">
      <a class="ufo-figure-link masthead__figure-link" href={`/dossier/${HOTTEL_SLUG}`} aria-label="Open the Guy Hottel memo dossier">
        <figure class="masthead__figure">
          <img
            src="/img/archive/hottel-memo-1950.jpg"
            alt="FBI memorandum from Guy Hottel to J. Edgar Hoover, March 22, 1950, reporting three flying saucers recovered in New Mexico."
            width="1200"
            height="1554"
            fetchpriority="high"
          />
          <figcaption>
            GUY HOTTEL TO HOOVER &nbsp;/&nbsp; 22 MARCH 1950 &nbsp;/&nbsp; FBI 62-83894
          </figcaption>
        </figure>
      </a>
      <div class="masthead__text">
        <p class="masthead__eyebrow">
          <a href="/about">RELEASED {stats.releaseDate}</a>
          <span class="masthead__eyebrow-sep">·</span>
          <a href="/timeline">{stats.totalCases} INDEXED</a>
          <span class="masthead__eyebrow-sep">·</span>
          <a href="/threads">{String(stats.threadCount).padStart(2, '0')} THREADS</a>
        </p>
        <h1 class="masthead__title">
          The files,<br />in one place.
        </h1>
        <p class="masthead__lede">
          FBI 62-HQ-83894 and the May 8, 2026 PURSUE release. Witnesses, agencies,
          and contradictions threaded through both. Every claim links back to the
          page it came from.
        </p>
        <p class="masthead__links">
          <a href="/threads">Read by thread</a>
          <span class="masthead__sep">·</span>
          <a href={`/dossier/${ARNOLD_SLUG}`}>Open a case</a>
          <span class="masthead__sep">·</span>
          <a href="/board">Open the board</a>
        </p>
      </div>
    </div>
  </section>

  <section class="pull">
    <div class="pull__grid">
      <a class="ufo-figure-link pull__figure-link" href={`/dossier/${featured?.id}`} aria-label={`Open ${tidyTitle(featured?.data.title)}`}>
        <figure class="pull__figure">
          <img
            src="/img/archive/arnold-aaf-document.jpg"
            alt="Kenneth Arnold's hand-drawn sketch from his July 12, 1947 Army Air Forces intelligence report, showing the nine objects he observed near Mount Rainier."
            width="700"
            height="900"
            loading="lazy"
          />
          <figcaption>
            ARNOLD AAF REPORT &nbsp;/&nbsp; 12 JULY 1947
          </figcaption>
        </figure>
      </a>
      <div class="pull__text">
        <p class="pull__case-id">
          <a href={`/dossier/${featured?.id}`}>{(featured?.data as any)?.caseId ?? featured?.id}</a>
        </p>
        <a href={`/dossier/${featured?.id}`} class="pull__title-link">
          <h2 class="pull__title">{tidyTitle(featured?.data.title)}</h2>
        </a>
        <p class="pull__excerpt">
          {(featured?.data as any)?.excerpt ?? (featured?.data as any)?.summary ?? ''}
        </p>
        <p class="pull__meta">
          <a href="/timeline">{(featured?.data as any)?.agency ?? 'FBI'}</a>
          &nbsp;/&nbsp;
          <a href="/timeline">{caseDate(featured)}</a>
          &nbsp;/&nbsp;
          <span>CONFIDENCE {String((featured?.data as any)?.confidence ?? 'low').toUpperCase()}</span>
        </p>
      </div>
    </div>
  </section>

  <section class="frontpage">
    <p class="frontpage__eyebrow">
      <a href="/thread/1947-origin">ONE PAGE FROM THE RECORD &nbsp;/&nbsp; 1947 ORIGIN ↗</a>
    </p>
    <a class="ufo-figure-link frontpage__figure-link" href="/thread/1947-origin" aria-label="Read the 1947 origin thread">
      <figure class="frontpage__figure">
        <img
          src="/img/archive/roswell-daily-record-july-8-1947.jpg"
          alt="Front page of the Roswell Daily Record, July 8, 1947, with the headline 'RAAF Captures Flying Saucer On Ranch in Roswell Region.'"
          width="1600"
          height="900"
          loading="lazy"
        />
        <figcaption>
          ROSWELL DAILY RECORD &nbsp;/&nbsp; 8 JULY 1947 &nbsp;/&nbsp; PUBLIC DOMAIN
        </figcaption>
      </figure>
    </a>
    <p class="frontpage__note">
      The headline ran one day. The <a href="/thread/1947-origin">retraction</a>
      ran the next. Both pages are in the file. So is the press release the
      RAAF issued before the retraction.
    </p>
  </section>

  <section class="index">
    <a class="ufo-section-anchor index__anchor" href="/timeline">
      <span class="ufo-section-anchor__num">{stats.totalCases}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Files in the archive</span>
        <span class="ufo-section-anchor__sublabel">Latest {latest.length} below &nbsp;/&nbsp; {stats.fbiCount} FBI &nbsp;/&nbsp; {stats.pursueCount} PURSUE</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Full timeline</span>
    </a>
    <ol class="index__list">
      {latest.map((c, i) => {
        const img = caseImage(c.id);
        return (
          <li class="index-row" data-has-image={img ? 'true' : undefined}>
            <a href={`/dossier/${c.id}`} class="index-row__link ufo-row-link">
              <span class="index-row__num ufo-row-link__dim">{String(i + 1).padStart(2, '0')}</span>
              <span class="index-row__thumb">
                {img && (
                  <img src={img.src} alt="" width="80" height="56" loading="lazy" />
                )}
              </span>
              <span class="index-row__date ufo-row-link__mid">{caseDate(c) || '----'}</span>
              <span class="index-row__title ufo-row-link__fg">{tidyTitle(c.data.title)}</span>
              <span class="index-row__agency ufo-row-link__dim">{archiveOf(c) === 'pursue' ? 'PURSUE' : 'FBI'}</span>
            </a>
          </li>
        );
      })}
    </ol>
    <p class="index__more">
      <a href="/timeline">View all on the timeline ↗</a>
    </p>
  </section>

  <section class="threads-section">
    <a class="ufo-section-anchor threads-section__anchor" href="/threads">
      <span class="ufo-section-anchor__num">{String(stats.threadCount).padStart(2, '0')}</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Threads run through it</span>
        <span class="ufo-section-anchor__sublabel">Spines that pull cases together</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Read by thread</span>
    </a>
    <ol class="threads-section__list">
      {THREADS.map((t, i) => (
        <li class="threads-row">
          <a href={`/thread/${t.id}`} class="threads-row__link ufo-row-link">
            <span class="threads-row__num ufo-row-link__dim">{String(i + 1).padStart(2, '0')}</span>
            <span class="threads-row__title ufo-row-link__fg">{t.title}</span>
            <span class="threads-row__span ufo-row-link__dim">{t.span}</span>
            <span class="threads-row__count ufo-row-link__mid">{countByThread.get(t.id) ?? 0}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <section class="archivist">
    <p class="archivist__eyebrow">
      <a href="/about">THE ARCHIVIST ↗</a>
    </p>
    <p class="archivist__body">
      I was eight years old when I first heard
      <a href="/thread/1947-origin">Roswell</a>.
      Thirty years later the government
      <a href="/timeline">published the file</a>.
      I read it cover to cover. There are cases in there nobody on cable news
      got to. There are cases that contradict each other.
      {hasApollo
        ? <>There is <a href={`/dossier/${APOLLO_SLUG}`}>one photo from the lunar surface</a> nobody has cleanly explained.</>
        : <>There is one photo from the lunar surface nobody has cleanly explained.</>
      }
    </p>
    <p class="archivist__body">
      This archive puts every page in one place so a stranger can land at the
      start, <a href="/threads">follow the files</a>, and decide for themselves.
    </p>
    <p class="archivist__sign">
      <a href="/about">David Russell · Houlton, Maine ↗</a>
    </p>
  </section>

</Base>

<style>
  main { width: 100%; }

  /* All sections use the same vertical-rhythm container. */
  .masthead, .pull, .index, .threads-section, .archivist {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }
  @media (max-width: 720px) {
    .masthead, .pull, .index, .threads-section, .archivist {
      padding: 0 16px;
    }
  }

  /* ── MASTHEAD ─────────────────────────────────────────── */
  .masthead {
    padding-top: 80px;
    padding-bottom: 96px;
  }
  @media (max-width: 720px) {
    .masthead { padding-top: 40px; padding-bottom: 56px; }
  }
  .masthead__grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: 48px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .masthead__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  .masthead__figure-link { margin: 0; }
  .masthead__figure { margin: 0; position: relative; }
  .masthead__figure img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(1) contrast(1.08);
    background: var(--fg);
  }
  @media (max-width: 900px) {
    .masthead__figure { max-height: 70vh; overflow: hidden; }
    .masthead__figure img { max-height: 70vh; object-fit: cover; object-position: top center; }
  }
  .masthead__text {
    position: sticky;
    top: 64px;
    align-self: start;
  }
  @media (max-width: 900px) {
    .masthead__text { position: static; }
  }
  .masthead__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--fg-dim);
    margin: 0 0 40px;
    display: flex;
    flex-wrap: wrap;
    gap: 0 12px;
    align-items: center;
    text-transform: uppercase;
  }
  .masthead__eyebrow a {
    color: var(--fg-mid);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .masthead__eyebrow a:hover,
  .masthead__eyebrow a:focus-visible {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .masthead__eyebrow-sep { color: var(--fg-dim); opacity: 0.6; }
  .masthead__title {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(56px, 9vw, 144px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    margin: 0 0 40px;
    color: var(--fg);
  }
  .masthead__lede {
    font-family: var(--font-body);
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.45;
    color: var(--fg-mid);
    max-width: 52ch;
    margin: 0 0 48px;
  }
  .masthead__links {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 18px;
    align-items: center;
  }
  .masthead__links a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 6px;
  }
  .masthead__links a:hover { text-decoration-color: var(--fg); }
  .masthead__sep { color: var(--fg-dim); }

  /* ── PULL (the one featured case) ─────────────────────── */
  .pull {
    padding: 96px 32px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-top: 0;
  }
  @media (max-width: 720px) {
    .pull { padding: 56px 16px; }
  }
  .pull__grid {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .pull__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
  .pull__figure-link { max-width: 480px; }
  .pull__figure { margin: 0; }
  .pull__figure img {
    width: 100%;
    max-width: 480px;
    height: auto;
    display: block;
    filter: grayscale(1) contrast(1.1) invert(1);
    background: var(--bg);
  }
  .pull__figure-link figcaption {
    max-width: 480px;
  }
  .pull__case-id {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0 0 20px;
  }
  .pull__case-id a {
    color: var(--fg-dim);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .pull__case-id a:hover,
  .pull__case-id a:focus-visible {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .pull__title-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .pull__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin: 0 0 24px;
    max-width: 22ch;
  }
  .pull__title-link:hover .pull__title {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 6px;
  }
  .pull__excerpt {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.55;
    color: var(--fg-mid);
    margin: 0 0 24px;
  }
  .pull__meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 8px;
    align-items: center;
  }
  .pull__meta a {
    color: var(--fg-dim);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .pull__meta a:hover,
  .pull__meta a:focus-visible {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }

  /* ── FRONT PAGE ───────────────────────────────────────── */
  .frontpage {
    max-width: 1400px;
    margin: 0 auto;
    padding: 96px 32px;
  }
  @media (max-width: 720px) {
    .frontpage { padding: 56px 16px; }
  }
  .frontpage__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--fg-dim);
    margin: 0 0 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--rule);
    text-transform: uppercase;
  }
  .frontpage__eyebrow a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .frontpage__eyebrow a:hover,
  .frontpage__eyebrow a:focus-visible {
    border-bottom-color: var(--fg);
  }
  .frontpage__figure-link { display: block; margin: 0 0 32px; }
  .frontpage__figure { margin: 0; }
  .frontpage__figure img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(1) contrast(1.05);
    background: var(--fg);
  }
  .frontpage__note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.35;
    color: var(--fg);
    max-width: 40ch;
    margin: 0;
  }
  .frontpage__note a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 4px;
    font-style: italic;
  }
  .frontpage__note a:hover,
  .frontpage__note a:focus-visible {
    text-decoration-color: var(--fg);
  }

  /* ── INDEX (latest list) ──────────────────────────────── */
  .index, .threads-section, .archivist {
    padding-top: 96px;
    padding-bottom: 0;
  }
  @media (max-width: 720px) {
    .index, .threads-section, .archivist {
      padding-top: 56px;
    }
  }
  .index__list { margin: 0; padding: 0; }
  .index-row { border-bottom: 1px solid var(--rule); }
  .index-row__link {
    grid-template-columns: 48px 96px 110px 1fr 70px;
    gap: 20px;
  }
  .index-row__num,
  .index-row__date,
  .index-row__agency {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .index-row__date { color: var(--fg-mid); }
  .index-row__agency { text-align: right; }
  .index-row__title {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.25;
    color: var(--fg);
  }
  .index-row__thumb {
    display: block;
    width: 96px;
    height: 64px;
    overflow: hidden;
    background: transparent;
  }
  .index-row__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(1) contrast(1.05);
    display: block;
  }
  /* Hover-invert handles its own contrast for the inner thumb. */
  .index-row__link:hover .index-row__thumb img,
  .index-row__link:focus-visible .index-row__thumb img {
    filter: grayscale(1) contrast(1.05) invert(1);
  }
  @media (max-width: 720px) {
    .index-row__link {
      grid-template-columns: 32px 64px 1fr;
      gap: 12px;
    }
    .index-row__date,
    .index-row__agency { display: none; }
    .index-row__thumb { width: 64px; height: 44px; }
    .index-row__title { font-size: 16px; }
  }
  .index__more {
    margin: 32px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .index__more a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 6px;
  }
  .index__more a:hover { text-decoration-color: var(--fg); }

  /* ── THREADS SECTION ──────────────────────────────────── */
  .threads-section__list { margin: 0; padding: 0; }
  .threads-row { border-bottom: 1px solid var(--rule); }
  .threads-row__link {
    grid-template-columns: 56px 1fr auto 60px;
    gap: 20px;
    align-items: baseline;
  }
  .threads-row__num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--fg-dim);
  }
  .threads-row__title {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.2;
    color: var(--fg);
  }
  .threads-row__span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }
  .threads-row__count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--fg-mid);
    text-align: right;
  }
  @media (max-width: 720px) {
    .threads-row__link {
      grid-template-columns: 36px 1fr;
      gap: 12px;
    }
    .threads-row__span,
    .threads-row__count { display: none; }
    .threads-row__title { font-size: 17px; }
  }

  /* ── ARCHIVIST ────────────────────────────────────────── */
  .archivist {
    padding-bottom: 120px;
  }
  @media (max-width: 720px) {
    .archivist { padding-bottom: 64px; }
  }
  .archivist__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    margin: 0 0 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--rule);
    text-transform: uppercase;
  }
  .archivist__eyebrow a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .archivist__eyebrow a:hover,
  .archivist__eyebrow a:focus-visible {
    border-bottom-color: var(--fg);
  }
  .archivist__body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--fg);
    max-width: 32ch;
    margin: 0 0 24px;
  }
  .archivist__body a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-decoration-color: var(--fg-dim);
