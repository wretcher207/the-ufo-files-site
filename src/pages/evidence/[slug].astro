---
import Base from '../../layouts/Base.astro';
import { archiveOf, getRenderableCases, headlineDate, threadOf, tidyTitle } from '../../lib/case-utils';
import ProvenanceCard from '../../components/ProvenanceCard.astro';

export async function getStaticPaths() {
  const cases = await getRenderableCases();
  return cases
    .filter((c) => c.data.origin_url)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const archive = archiveOf(entry);
const thread = threadOf(entry);
const date = headlineDate(entry);
const headline = tidyTitle(entry.data.title);

const url = entry.data.origin_url;
const isImage = /\.(jpg|jpeg|png|gif|webp)(\?|$)/i.test(url);
const isVideo = /\.(mp4|mov|webm|m4v)(\?|$)/i.test(url);
const isPdf = /\.pdf(\?|$)/i.test(url);

const archiveLabel = archive === 'pursue' ? 'PURSUE Release 01' : 'FBI 62-HQ-83894';
---
<Base
  title={'Evidence — ' + headline}
  description={'War.gov source media linked to ' + headline}
  section="EVIDENCE"
>
  <main class="ev-main" id="main">

    <a class="ufo-section-anchor ev-anchor" href={`/dossier/${entry.id}`}>
      <span class="ufo-section-anchor__num">↩</span>
      <span class="ufo-section-anchor__body">
        <span class="ufo-section-anchor__label">Evidence &nbsp;/&nbsp; Source media</span>
        <span class="ufo-section-anchor__sublabel">{archiveLabel}{date && <> &nbsp;/&nbsp; {date}</>}</span>
      </span>
      <span class="ufo-section-anchor__arrow">↗ Back to dossier</span>
    </a>

    <header class="ev-hero">
      <h1 class="ev-title">{headline}</h1>
      <p class="ev-meta">
        <a href="/timeline">{archiveLabel}</a>
        {date && <> &nbsp;/&nbsp; <a href="/timeline">{date}</a></>}
        {thread && <> &nbsp;/&nbsp; <a href={`/thread/${thread.id}`}>{thread.title}</a></>}
      </p>
    </header>

    <section class="ev-frame" aria-labelledby="ev-frame-h">
      <header class="ev-frame__head">
        <h2 id="ev-frame-h" class="ev-frame__label">Source material</h2>
        <a class="ev-frame__status" href={url} rel="noopener external" target="_blank">
          Hot-linked from war.gov ↗
        </a>
      </header>

      <div class="ev-frame__body">
        {isImage && (
          <a href={url} rel="noopener external" target="_blank">
            <img src={url} alt={'War.gov source image for ' + headline} loading="lazy" />
          </a>
        )}
        {isVideo && (
          <video controls preload="metadata" src={url}>
            Your browser cannot play this video.
            <a href={url} rel="noopener external" target="_blank">Open at war.gov</a>.
          </video>
        )}
        {isPdf && (
          <object data={url} type="application/pdf">
            <p>
              Embedded PDF viewer unavailable.
              <a href={url} rel="noopener external" target="_blank">Open the PDF at war.gov ↗</a>
            </p>
          </object>
        )}
        {!isImage && !isVideo && !isPdf && (
          <p class="ev-frame__fallback">
            The source file type cannot be embedded directly.
            <a href={url} rel="noopener external" target="_blank">Open at war.gov ↗</a>
          </p>
        )}
      </div>
    </section>

    <ProvenanceCard entry={entry} />

    <a class="ev-back" href={'/dossier/' + entry.id}>↩ Back to dossier</a>

  </main>
</Base>

<style>
  .ev-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 80px 32px 120px;
  }
  @media (max-width: 720px) {
    .ev-main { padding: 48px 16px 80px; }
  }

  .ev-anchor { margin-bottom: 48px; }
  .ev-anchor .ufo-section-anchor__num {
    font-size: clamp(48px, 7vw, 96px);
  }

  .ev-hero {
    margin: 0 0 48px;
    max-width: 60ch;
  }
  .ev-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0 0 16px;
    max-width: 30ch;
  }
  .ev-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0 4px;
    align-items: center;
  }
  .ev-meta a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .ev-meta a:hover, .ev-meta a:focus-visible {
    border-bottom-color: var(--fg);
  }

  .ev-frame {
    border-top: 1px solid var(--fg);
    border-bottom: 1px solid var(--rule);
    padding: 24px 0 32px;
    margin: 0 0 56px;
  }
  .ev-frame__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .ev-frame__label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fg);
    margin: 0;
  }
  .ev-frame__status {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-mid);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .ev-frame__status:hover, .ev-frame__status:focus-visible {
    color: var(--fg);
    border-bottom-color: var(--fg);
  }
  .ev-frame__body {
    position: relative;
    min-height: 320px;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ev-frame__body img {
    display: block;
    max-width: 100%;
    height: auto;
    filter: grayscale(1) contrast(1.05);
  }
  .ev-frame__body video {
    display: block;
    max-width: 100%;
    max-height: 70vh;
    background: var(--bg);
  }
  .ev-frame__body object {
    width: 100%;
    min-height: 70vh;
  }
  .ev-frame__body a:hover img,
  .ev-frame__body a:focus-visible img {
    outline: 2px solid var(--fg);
    outline-offset: -1px;
  }
  .ev-frame__fallback {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    color: var(--fg-mid);
    text-transform: uppercase;
  }
  .ev-frame__fallback a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--fg-dim);
    text-underline-offset: 4px;
    margin-left: 8px;
  }
  .ev-frame__fallback a:hover { text-decoration-color: var(--fg); }

  .ev-back {
    display: inline-block;
    margin-top: 48px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg);
    padding: 12px 16px;
    margin-left: -16px;
    text-decoration: none;
    transition: background-color var(--dur-quick) linear,
                color var(--dur-quick) linear;
  }
  .ev-back:hover,
  .ev-back:focus-visible {
    background: var(--fg);
    color: var(--bg);
    outline: none;
  }
</style>
