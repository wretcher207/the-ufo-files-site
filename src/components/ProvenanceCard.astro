---
import type { AnyCase } from '../lib/case-utils';

interface Props { entry: AnyCase; }
const { entry } = Astro.props;
const { origin_url, mirror_url, source } = entry.data;

// `source` is either the legacy comma-list string of OCR pages, or the Phase 6
// source object. Only the string form populates the OCR pages list.
const sourceString = typeof source === 'string' ? source : '';
const sourcePages = sourceString
  ? sourceString.split(',').map((s) => s.trim()).filter(Boolean)
  : [];
---
<aside class="provenance" aria-labelledby="provenance-heading">
  <header class="provenance__head">
    <span class="provenance__label">Provenance</span>
    <h2 id="provenance-heading" class="provenance__title">Source &amp; chain of custody</h2>
  </header>

  {origin_url && (
    <a class="provenance__primary" href={origin_url} rel="noopener external" target="_blank">
      <span class="provenance__primary-label">Original at war.gov</span>
      <span class="provenance__primary-url">{origin_url.replace(/^https?:\/\//, '')}</span>
      <span class="provenance__primary-action" aria-hidden="true">↗</span>
    </a>
  )}

  {mirror_url && (
    <a class="provenance__secondary" href={mirror_url} rel="noopener external" target="_blank">
      Mirror: {mirror_url.replace(/^https?:\/\//, '')} ↗
    </a>
  )}

  {sourcePages.length > 0 && (
    <details class="provenance__pages">
      <summary>OCR source pages ({sourcePages.length})</summary>
      <ul>
        {sourcePages.slice(0, 12).map((p) => <li>{p}</li>)}
        {sourcePages.length > 12 && <li>… {sourcePages.length - 12} more</li>}
      </ul>
    </details>
  )}
</aside>

<style>
  .provenance {
    border-top: 1px solid var(--border);
    padding: var(--sp-5) 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
  .provenance__head { display: flex; flex-direction: column; gap: var(--sp-2); }
  .provenance__label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .provenance__title {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    line-height: var(--lh-snug);
    color: var(--fg-1);
    margin: 0;
    font-weight: 500;
  }
  .provenance__primary {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--sp-2) var(--sp-4);
    padding: var(--sp-4);
    background: var(--bg-2);
    border-top: 1px solid var(--crt-glow);
    text-decoration: none;
    color: var(--fg-1);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .provenance__primary:hover {
    background: var(--bg-3);
  }
  .provenance__primary-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--crt-glow);
  }
  .provenance__primary-url {
    grid-column: 1;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--fg-1);
    word-break: break-all;
  }
  .provenance__primary-action {
    grid-row: 1 / span 2;
    grid-column: 2;
    font-size: var(--fs-lg);
    color: var(--crt-glow);
    align-self: center;
  }
  .provenance__secondary {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-2);
    word-break: break-all;
  }
  .provenance__pages {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-3);
  }
  .provenance__pages summary {
    cursor: pointer;
    color: var(--fg-2);
    letter-spacing: var(--tracking-wide);
  }
  .provenance__pages ul {
    margin: var(--sp-2) 0 0;
    padding-left: var(--sp-4);
    color: var(--fg-3);
    word-break: break-all;
  }
</style>
