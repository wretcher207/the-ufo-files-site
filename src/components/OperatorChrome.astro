---
import SearchHUD from './SearchHUD.astro';

interface Props {
  pathname?: string;
}
const { pathname = '/' } = Astro.props;

const navLinks: { href: string; label: string; matchPrefixes: string[] }[] = [
  { href: '/',         label: 'Archive',  matchPrefixes: ['/'] },
  { href: '/threads',  label: 'Threads',  matchPrefixes: ['/threads', '/thread'] },
  { href: '/board',    label: 'Board',    matchPrefixes: ['/board'] },
  { href: '/atlas',    label: 'Atlas',    matchPrefixes: ['/atlas'] },
  { href: '/timeline', label: 'Timeline', matchPrefixes: ['/timeline'] },
  { href: '/map',      label: 'Map',      matchPrefixes: ['/map'] },
  { href: '/about',    label: 'About',    matchPrefixes: ['/about'] },
];

function isActive(prefixes: string[]) {
  if (pathname === '/') return prefixes.includes('/');
  return prefixes.some((p) => p !== '/' && pathname.startsWith(p));
}
---
<header class="operator-chrome" data-operator-chrome>
  <div class="operator-chrome__inner">
    <a href="/" class="operator-chrome__brand" aria-label="The UFO Files, home">
      THE UFO FILES
    </a>

    <nav class="operator-chrome__nav" aria-label="Primary">
      {navLinks.slice(1).map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.matchPrefixes) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="operator-chrome__right">
      <SearchHUD />
      <button
        type="button"
        class="operator-chrome__hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        data-mobile-toggle
      >
        <svg width="16" height="14" viewBox="0 0 16 14" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="square">
          <line x1="0" y1="1" x2="16" y2="1" />
          <line x1="0" y1="7" x2="16" y2="7" />
          <line x1="0" y1="13" x2="16" y2="13" />
        </svg>
      </button>
    </div>
  </div>

  <nav class="operator-chrome__mobile-menu" aria-label="Mobile">
    {navLinks.map((link) => (
      <a
        href={link.href}
        aria-current={isActive(link.matchPrefixes) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const chrome = document.querySelector('[data-operator-chrome]') as HTMLElement | null;
  const toggle = document.querySelector('[data-mobile-toggle]') as HTMLButtonElement | null;

  if (chrome && toggle) {
    toggle.addEventListener('click', () => {
      const open = chrome.getAttribute('data-mobile-open') === 'true';
      if (open) {
        chrome.removeAttribute('data-mobile-open');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        chrome.setAttribute('data-mobile-open', 'true');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
    chrome.querySelectorAll('.operator-chrome__mobile-menu a').forEach((a) => {
      a.addEventListener('click', () => {
        chrome.removeAttribute('data-mobile-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
