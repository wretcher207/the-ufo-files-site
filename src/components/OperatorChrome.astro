---
import SearchHUD from './SearchHUD.astro';

interface Props {
  serial?: string;
  section?: string;
  status?: 'ok' | 'warn' | 'error';
  pathname?: string;
}
const {
  serial = 'UAS://ARCHIVE/OPEN',
  section = '',
  status = 'ok',
  pathname = '/',
} = Astro.props;

const navLinks: { href: string; label: string; matchPrefixes: string[] }[] = [
  { href: '/', label: 'Case Board', matchPrefixes: ['/'] },
  { href: '/atlas', label: 'Atlas', matchPrefixes: ['/atlas'] },
  { href: '/timeline', label: 'Timeline', matchPrefixes: ['/timeline'] },
  { href: '/map', label: 'Map', matchPrefixes: ['/map'] },
  { href: '/graph', label: 'Graph', matchPrefixes: ['/graph'] },
  { href: '/vault', label: 'Vault', matchPrefixes: ['/vault'] },
  { href: '/about', label: 'Methodology', matchPrefixes: ['/about'] },
];

function isActive(prefixes: string[]) {
  if (pathname === '/') return prefixes.includes('/');
  return prefixes.some((p) => p !== '/' && pathname.startsWith(p));
}

const coord = serial.replace(/^UAS:\/\//, '');
---
<header class="operator-chrome">
  <div class="operator-chrome__inner">
    <a href="/" class="operator-chrome__brand" aria-label="The UFO Files — home">
      <span class="operator-chrome__brand-mark">The UFO Files</span>
      <span class="operator-chrome__brand-sub">The Unsealed Archive</span>
    </a>

    <div class="operator-chrome__center">
      <div class="operator-chrome__serial" role="status" aria-live="polite" data-status={status}>
        <span class="operator-chrome__serial-dot" aria-hidden="true"></span>
        <span>{coord}{section ? ` · ${section}` : ''}</span>
      </div>
    </div>

    <div class="operator-chrome__right">
      <SearchHUD />
      <nav class="operator-chrome__nav" aria-label="Primary">
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.matchPrefixes) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
