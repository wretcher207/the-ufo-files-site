---
// Platform-agnostic search trigger. Pagefind backs the index.
---
<button class="search-trigger" aria-label="Search archive" data-search-open>
  <span class="search-trigger__icon" aria-hidden="true">/</span>
  <span class="search-trigger__label">Search</span>
</button>

<div class="search-hud" data-search-hud hidden role="dialog" aria-modal="true" aria-label="Search archive">
  <div class="search-hud__scrim" data-search-close></div>
  <div class="search-hud__panel" role="document">
    <div class="search-hud__head">
      <input
        type="search"
        class="search-hud__input"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        placeholder="Arnold, Hottel, Apollo 17, Maury Island ..."
        data-search-input
      />
      <button class="search-hud__close" data-search-close aria-label="Close search">ESC</button>
    </div>
    <div class="search-hud__results" data-search-results aria-live="polite">
      <p class="search-hud__hint">Type to search every case and entity.</p>
    </div>
  </div>
</div>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    background: transparent;
    border: none;
    padding: 0;
    color: var(--fg-mid);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .search-trigger:hover { color: var(--fg); }
  .search-trigger__icon {
    font-family: var(--font-mono);
    font-size: 15px;
    line-height: 1;
    color: var(--fg);
  }
  @media (max-width: 640px) {
    .search-trigger__label { display: none; }
  }

  .search-hud {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }
  .search-hud[hidden] { display: none; }
  .search-hud__scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
  }
  .search-hud__panel {
    position: relative;
    width: min(720px, calc(100% - 32px));
    background: var(--bg);
    border: 1px solid var(--fg);
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }
  .search-hud__head {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--rule);
  }
  .search-hud__input {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--fg);
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: -0.01em;
    outline: none;
    padding: 18px 20px;
    min-width: 0;
  }
  .search-hud__input::placeholder { color: var(--fg-dim); }
  .search-hud__close {
    background: transparent;
    border: none;
    border-left: 1px solid var(--rule);
    color: var(--fg-mid);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    padding: 0 18px;
    cursor: pointer;
  }
  .search-hud__close:hover { color: var(--fg); }
  .search-hud__results {
    overflow-y: auto;
    padding: 16px 20px 20px;
    flex: 1;
    min-height: 100px;
  }
  .search-hud__hint {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-dim);
    margin: 0;
    text-transform: uppercase;
  }
  .search-hud__result {
    display: block;
    padding: 14px 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
  }
  .search-hud__result:last-child { border-bottom: none; }
  .search-hud__result:hover .search-hud__result-title {
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .search-hud__result-title {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--fg);
    line-height: 1.2;
    display: block;
    margin-bottom: 4px;
  }
  .search-hud__result-excerpt {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--fg-mid);
    line-height: 1.4;
    display: block;
  }
  .search-hud__result mark {
    background: var(--fg);
    color: var(--bg);
    padding: 0 2px;
  }
</style>

<script>
  const trigger = document.querySelector('[data-search-open]') as HTMLButtonElement | null;
  const hud = document.querySelector('[data-search-hud]') as HTMLElement | null;
  const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
  const results = document.querySelector('[data-search-results]') as HTMLElement | null;
  const closers = document.querySelectorAll('[data-search-close]');

  let timer: number | null = null;
  let pf: any = null;

  function open() {
    if (!hud) return;
    hud.hidden = false;
    setTimeout(() => input?.focus(), 0);
    document.body.style.overflow = 'hidden';
  }
  function close() {
    if (!hud) return;
    hud.hidden = true;
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (results) results.innerHTML = '<p class="search-hud__hint">Type to search every case and entity.</p>';
  }

  trigger?.addEventListener('click', open);
  closers.forEach((c) => c.addEventListener('click', close));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && hud && !hud.hidden) {
      e.preventDefault();
      close();
      return;
    }
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      if (hud) (hud.hidden ? open() : close());
      return;
    }
    if (e.key === '/' && hud && hud.hidden) {
      const tag = (e.target as HTMLElement | null)?.tagName?.toLowerCase();
      if (tag !== 'input' && tag !== 'textarea') {
        e.preventDefault();
        open();
      }
    }
  });

  input?.addEventListener('input', () => {
    if (timer) window.clearTimeout(timer);
    timer = window.setTimeout(async () => {
      const q = input!.value.trim();
      if (!q) {
        if (results) results.innerHTML = '<p class="search-hud__hint">Type to search every case and entity.</p>';
        return;
      }
      try {
        if (!pf) {
          // @ts-ignore
          pf = await import('/pagefind/pagefind.js');
          await pf.options?.({ baseUrl: '/' });
        }
        const search = await pf.search(q);
        const top = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));
        if (!results) return;
        if (top.length === 0) {
          results.innerHTML = '<p class="search-hud__hint">No matches.</p>';
          return;
        }
        results.innerHTML = top.map((d: any) => `
          <a class="search-hud__result" href="${d.url}">
            <span class="search-hud__result-title">${d.meta?.title ?? d.url}</span>
            <span class="search-hud__result-excerpt">${d.excerpt ?? ''}</span>
          </a>
        `).join('');
      } catch (err) {
        console.error('[search] pagefind failed', err);
        if (results) results.innerHTML = '<p class="search-hud__hint">Search unavailable. In dev, run a build first.</p>';
      }
    }, 120);
  });
</script>
