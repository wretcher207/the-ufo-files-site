---
// CMD/CTRL + K search HUD. Vanilla JS island, queries Pagefind index built at /pagefind/.
---
<button class="search-trigger" aria-label="Open search (Cmd or Ctrl K)" data-search-open>
  <span class="search-trigger__icon" aria-hidden="true">QUERY</span>
  <span class="search-trigger__label">Query archive</span>
  <span class="search-trigger__kbd"><kbd>CMD</kbd><kbd>K</kbd></span>
</button>

<div class="search-hud" data-search-hud hidden role="dialog" aria-modal="true" aria-label="Search archive">
  <div class="search-hud__scrim" data-search-close></div>
  <div class="search-hud__panel" role="document">
    <header class="search-hud__head">
      <span class="search-hud__prompt" aria-hidden="true">QUERY ARCHIVE&nbsp;</span>
      <input type="search" class="search-hud__input" autocomplete="off" autocorrect="off" spellcheck="false" placeholder="ARNOLD / HOTTEL / OAK RIDGE / APOLLO 17 ..." data-search-input />
      <button class="search-hud__close" data-search-close aria-label="Close search">ESC</button>
    </header>
    <div class="search-hud__results" data-search-results aria-live="polite">
      <p class="search-hud__hint">Search across all 62 cases. Indexed on every build.</p>
    </div>
    <footer class="search-hud__foot">
      <span><kbd>UP</kbd><kbd>DN</kbd> navigate</span>
      <span><kbd>ENT</kbd> open</span>
      <span><kbd>ESC</kbd> close</span>
    </footer>
  </div>
</div>

<style>
  .search-trigger { display: flex; align-items: center; gap: var(--sp-2); background: transparent; border: 1px solid var(--border); color: var(--fg-2); font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: var(--tracking-wider); text-transform: uppercase; padding: 6px 10px; cursor: pointer; transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out); }
  .search-trigger:hover { background: var(--bg-2); color: var(--fg-1); }
  .search-trigger__icon { color: var(--crt-glow); font-family: var(--font-mono); font-size: 10px; letter-spacing: var(--tracking-wider); }
  .search-trigger__kbd { display: flex; gap: 2px; color: var(--fg-3); }
  .search-trigger__kbd kbd { font-family: var(--font-mono); font-size: 10px; padding: 1px 5px; border: 1px solid var(--border); color: var(--fg-3); background: var(--bg-1); }
  @media (max-width: 640px) { .search-trigger__label { display: none; } .search-trigger__kbd { display: none; } }

  .search-hud { position: fixed; inset: 0; z-index: 100; display: flex; align-items: flex-start; justify-content: center; padding-top: 10vh; }
  .search-hud[hidden] { display: none; }
  .search-hud__scrim { position: absolute; inset: 0; background: rgba(3, 5, 6, 0.85); backdrop-filter: blur(6px); }
  .search-hud__panel { position: relative; width: min(720px, calc(100% - var(--sp-5) * 2)); background: var(--bg-1); border: 1px solid var(--border-strong); box-shadow: var(--elev-bloom); display: flex; flex-direction: column; max-height: 75vh; }
  .search-hud__head { display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-4); border-bottom: 1px solid var(--border); }
  .search-hud__prompt { font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: var(--tracking-wider); color: var(--crt-glow); white-space: nowrap; }
  .search-hud__input { flex: 1; background: transparent; border: none; color: var(--fg-1); font-family: var(--font-mono); font-size: var(--fs-md); letter-spacing: var(--tracking-wide); outline: none; padding: 4px 0; min-width: 0; }
  .search-hud__input::placeholder { color: var(--fg-3); }
  .search-hud__close { background: transparent; border: 1px solid var(--border); color: var(--fg-2); font-family: var(--font-mono); font-size: var(--fs-xs); letter-spacing: var(--tracking-wider); padding: 4px 8px; cursor: pointer; }
  .search-hud__close:hover { color: var(--fg-1); border-color: var(--border-strong); }
  .search-hud__results { overflow-y: auto; padding: var(--sp-3) var(--sp-4); flex: 1; min-height: 100px; }
  .search-hud__hint { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--fg-3); margin: 0; }
  .search-hud__foot { border-top: 1px solid var(--border); padding: var(--sp-2) var(--sp-4); display: flex; gap: var(--sp-5); font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--fg-3); letter-spacing: var(--tracking-wide); }
  .search-hud__foot kbd { font-family: var(--font-mono); font-size: 10px; padding: 1px 5px; border: 1px solid var(--border); color: var(--fg-3); background: var(--bg-2); margin-right: 2px; }

  :global(.sh-result) { display: block; padding: var(--sp-3) 0; border-top: 1px solid var(--border-subtle); text-decoration: none; color: var(--fg-1); }
  :global(.sh-result[data-active="true"]) { background: var(--bg-2); margin-left: calc(var(--sp-4) * -1); margin-right: calc(var(--sp-4) * -1); padding-left: var(--sp-4); padding-right: var(--sp-4); }
  :global(.sh-result__title) { font-family: var(--font-ui); font-size: var(--fs-base); color: var(--fg-1); margin: 0 0 4px; line-height: var(--lh-snug); }
  :global(.sh-result__excerpt) { font-family: var(--font-ui); font-size: var(--fs-sm); line-height: var(--lh-snug); color: var(--fg-2); margin: 0; }
  :global(.sh-result__excerpt mark) { background: transparent; color: var(--crt-glow); font-weight: 500; }
  :global(.sh-empty) { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--fg-3); margin: 0; }
</style>

<script>
  const trigger = document.querySelector("[data-search-open]");
  const hud = document.querySelector("[data-search-hud]");
  const input = document.querySelector("[data-search-input]");
  const results = document.querySelector("[data-search-results]");
  const closers = document.querySelectorAll("[data-search-close]");

  if (hud && input && results) {
    let pagefind = null;
    let active = -1;
    let renderedResults = [];

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import(/* @vite-ignore */ "/pagefind/pagefind.js");
        await pagefind.options({ excerptLength: 30 });
      } catch (err) {
        console.warn("Pagefind not available (likely dev mode). Build the site to enable search.", err);
        pagefind = null;
      }
      return pagefind;
    }

    function open() {
      hud.removeAttribute("hidden");
      input.focus();
      loadPagefind();
    }
    function close() {
      hud.setAttribute("hidden", "");
      input.value = "";
      results.innerHTML = HINT_HTML;
      active = -1;
      renderedResults = [];
    }

    const HINT_HTML = '<p class="search-hud__hint">Search across all 62 cases. Indexed on every build.</p>';

    if (trigger) trigger.addEventListener("click", open);
    closers.forEach(function(c) { c.addEventListener("click", close); });

    document.addEventListener("keydown", function(e) {
      const isOpen = hud.getAttribute("hidden") === null;
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        if (isOpen) { close(); } else { open(); }
        return;
      }
      if (!isOpen) return;
      if (e.key === "Escape") { e.preventDefault(); close(); return; }
      if (e.key === "ArrowDown") { e.preventDefault(); focusResult(active + 1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); focusResult(active - 1); }
      else if (e.key === "Enter" && active >= 0 && renderedResults[active]) { renderedResults[active].click(); }
    });

    function focusResult(i) {
      if (renderedResults.length === 0) return;
      if (i < 0) i = 0;
      if (i >= renderedResults.length) i = renderedResults.length - 1;
      renderedResults.forEach(function(el) { el.removeAttribute("data-active"); });
      renderedResults[i].setAttribute("data-active", "true");
      renderedResults[i].scrollIntoView({ block: "nearest" });
      active = i;
    }

    let debounce;
    input.addEventListener("input", function() {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(runSearch, 110);
    });

    async function runSearch() {
      const q = input.value.trim();
      if (!q) {
        results.innerHTML = HINT_HTML;
        renderedResults = [];
        active = -1;
        return;
      }
      const pf = await loadPagefind();
      if (!pf) {
        results.innerHTML = '<p class="sh-empty">Search index is built at deploy time. Run npm run build to enable search locally, or check the deployed site.</p>';
        return;
      }
      const search = await pf.search(q);
      const top = await Promise.all(search.results.slice(0, 10).map(function(r) { return r.data(); }));
      if (top.length === 0) {
        results.innerHTML = '<p class="sh-empty">No matches.</p>';
        renderedResults = [];
        active = -1;
        return;
      }
      results.innerHTML = "";
      renderedResults = top.map(function(r) {
        const a = document.createElement("a");
        a.className = "sh-result";
        a.href = r.url;
        const t = document.createElement("p");
        t.className = "sh-result__title";
        t.textContent = (r.meta && r.meta.title) ? r.meta.title : r.url;
        const e = document.createElement("p");
        e.className = "sh-result__excerpt";
        e.innerHTML = r.excerpt;
        a.appendChild(t);
        a.appendChild(e);
        results.appendChild(a);
        return a;
      });
      focusResult(0);
    }
  }
</script>
