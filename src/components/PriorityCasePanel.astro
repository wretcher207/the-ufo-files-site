---
interface Props {
  variant: 'lead' | 'side-a' | 'side-b' | 'side-c';
  href: string;
  archive: 'fbi' | 'pursue';
  caseId: string;
  date?: string;
  signal?: 'high' | 'medium' | 'low';
  title: string;
  summary: string;
  chips?: string[];
  thread?: string;
}
const { variant, href, archive, caseId, date, signal, title, summary, chips = [], thread } = Astro.props;
---
<a class={`survivor survivor--${variant}`} href={href} data-archive={archive}>
  <div class="survivor__chrome">
    <div class="survivor__badges">
      <span class="survivor__badge survivor__badge--source">{archive === 'pursue' ? 'PURSUE' : 'FBI'}</span>
      {signal === 'high' && (
        <span class="survivor__badge survivor__badge--signal-high">SIG · HIGH</span>
      )}
    </div>
    <span class="survivor__id">{date ?? ''} {caseId && `· ${caseId}`}</span>
  </div>

  <h3 class="survivor__title">{title}</h3>
  <p class="survivor__summary">{summary}</p>

  {chips.length > 0 && (
    <div class="survivor__chips">
      {chips.map((chip) => <span class="survivor__chip">{chip}</span>)}
    </div>
  )}

  <div class="survivor__footer">
    <span>{thread ?? 'Filed dossier'}</span>
    <span class="survivor__cta">Open dossier →</span>
  </div>
</a>
