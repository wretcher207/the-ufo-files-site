---
/**
 * ProvenanceFooter.astro
 *
 * Hairline footer for the dossier reading plate AND any /saved row that wants
 * to surface source + retrieval metadata + archive commit pointer.
 *
 * Behavior:
 *   - source.officialUrl present  → render canonical link + retrieved + commit
 *   - source.officialUrl absent   → "Pending official release: May 8 2026" line
 */
import type { AnyCase } from '../lib/case-utils';

interface Props {
  entry: AnyCase;
}
const { entry } = Astro.props;
const src = entry.data.source;
const obj = src && typeof src === 'object' ? src : null;

const officialUrl =
  obj && typeof obj.officialUrl === 'string' && obj.officialUrl
    ? obj.officialUrl
    : typeof entry.data.origin_url === 'string'
      ? entry.data.origin_url
      : null;

const officialName =
  obj && typeof obj.officialName === 'string' ? obj.officialName : null;

const retrievedDate =
  obj && typeof obj.retrievedDate === 'string' ? obj.retrievedDate : null;

const archiveCommit =
  obj && typeof obj.archiveCommit === 'string' ? obj.archiveCommit : null;

const releaseDate =
  obj && typeof obj.releaseDate === 'string' ? obj.releaseDate : null;
---
<footer class="provenance-footer rule">
  <div class="provenance-footer__head">
    <span class="provenance-footer__label">PROVENANCE</span>
  </div>

  {officialUrl ? (
    <dl class="provenance-footer__grid">
      <div>
        <dt>Official source</dt>
        <dd>
          <a href={officialUrl} target="_blank" rel="noopener external">
            {officialName ?? officialUrl.replace(/^https?:\/\//, '')}
          </a>
        </dd>
      </div>
      {releaseDate && (
        <div>
          <dt>Release date</dt>
          <dd>{releaseDate}</dd>
        </div>
      )}
      {retrievedDate && (
        <div>
          <dt>Retrieved</dt>
          <dd>{retrievedDate}</dd>
        </div>
      )}
      {archiveCommit && (
        <div>
          <dt>Archive commit</dt>
          <dd class="provenance-footer__commit">{archiveCommit}</dd>
        </div>
      )}
    </dl>
  ) : (
    <p class="provenance-footer__pending">
      Pending official release: May 8 2026.
    </p>
  )}
</footer>

<style>
  .provenance-footer {
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
  }
  .provenance-footer__head {
    margin-bottom: var(--sp-4);
  }
  .provenance-footer__label {
    font-family: var(--font-mono);
    font-weight: var(--weight-mono-md);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .provenance-footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-5);
    margin: 0;
  }
  .provenance-footer__grid div {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .provenance-footer__grid dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0;
  }
  .provenance-footer__grid dd {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--ink-primary);
    margin: 0;
    word-break: break-word;
  }
  .provenance-footer__commit {
    word-break: break-all;
  }
  .provenance-footer__grid a {
    color: var(--ink-primary);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .provenance-footer__grid a:hover {
    color: var(--accent-amber);
    text-decoration-color: var(--accent-amber);
  }
  .provenance-footer__pending {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--ink-secondary);
    margin: 0;
    letter-spacing: var(--tracking-wide);
  }
</style>
