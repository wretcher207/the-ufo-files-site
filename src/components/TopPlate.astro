---
/**
 * TopPlate.astro
 *
 * Dossier Top Plate wrapper around Hero.astro. Reads case frontmatter and
 * constructs the satellite array. Reused tokens line up with /board node
 * visuals so the dossier feels like the same evidence rendered at a
 * different zoom level.
 */
import type { AnyCase } from '../lib/case-utils';
import Hero, { type SatelliteCard } from './Hero.astro';
import { archiveOf, headlineDate, tidyTitle } from '../lib/case-utils';

interface Props {
  entry: AnyCase;
}
const { entry } = Astro.props;
const data = entry.data;

const archive = archiveOf(entry);
const date = headlineDate(entry);
const title = tidyTitle(data.title);
const caseId =
  (typeof data.caseId === 'string' && data.caseId) ||
  `${archive === 'pursue' ? 'PURSUE' : 'FBI-62HQ-83894'}/${entry.id}`;

const agency =
  (typeof data.agency === 'string' && data.agency) ||
  (typeof data.publisher === 'string' && data.publisher) ||
  (archive === 'pursue' ? 'WAR.GOV / PURSUE' : 'FBI');

const classification =
  typeof data.classification === 'string' && data.classification
    ? data.classification
    : 'PUBLIC RELEASE';

const witnesses = Array.isArray(data.witnesses) ? data.witnesses.map(String) : [];
const heroAsset = data.heroAsset;
const geo = data.geo;
const summary = typeof data.summary === 'string' ? data.summary : null;
const nodeType = typeof data.nodeType === 'string' ? data.nodeType : 'document';

const eyebrow = [
  caseId,
  agency,
  date,
].filter(Boolean).join(' · ');

// Compose satellites in priority order, cap at 5.
const satellites: SatelliteCard[] = [];

if (heroAsset && (heroAsset.type === 'photo' || heroAsset.type === 'scan' || heroAsset.type === 'map')) {
  satellites.push({
    kind: heroAsset.type,
    eyebrow: heroAsset.type === 'photo' ? 'PHOTO' : heroAsset.type === 'scan' ? 'SCAN' : 'MAP',
    title: heroAsset.alt ?? `${heroAsset.type} record`,
    meta: heroAsset.credit ?? undefined,
    src: heroAsset.src ?? undefined,
    alt: heroAsset.alt ?? undefined,
    href: '#source-summary',
  });
}

if (witnesses.length > 0) {
  satellites.push({
    kind: 'witness',
    eyebrow: 'WITNESS',
    title: witnesses[0],
    meta: witnesses.length > 1 ? `+${witnesses.length - 1} more in file` : undefined,
    href: '#source-witnesses',
  });
}

satellites.push({
  kind: 'agency',
  eyebrow: 'AGENCY STAMP',
  title: agency,
  meta: classification,
  href: '#source-agency',
});

if (summary) {
  satellites.push({
    kind: 'evidence',
    eyebrow: 'EVIDENCE',
    title: summary.length > 140 ? summary.slice(0, 137) + '...' : summary,
    href: '#source-summary',
  });
}

if (nodeType === 'sighting' || geo) {
  satellites.push({
    kind: 'sighting',
    eyebrow: 'SIGHTING',
    title: geo?.placeName ? String(geo.placeName) : 'Reported location',
    meta: geo?.lat && geo?.lng ? `${geo.lat.toFixed(3)}, ${geo.lng.toFixed(3)}` : undefined,
    href: geo?.lat && geo?.lng ? '/map' : '#source-summary',
  });
}

// Don't render the same kind twice. Keep first instance.
const seen = new Set<string>();
const dedup = satellites.filter((s) => {
  if (seen.has(s.kind)) return false;
  seen.add(s.kind);
  return true;
}).slice(0, 5);
---
<Hero
  centerEyebrow={eyebrow}
  centerTitle={title}
  satellites={dedup}
  caseId={caseId}
  mode="static"
/>
