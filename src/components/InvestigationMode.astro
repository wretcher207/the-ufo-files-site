---
interface Props {
  href: string;
  id: string;
  title: string;
  desc: string;
  meta?: string;
  icon: 'board' | 'atlas' | 'timeline' | 'map' | 'graph' | 'vault' | 'start';
  disabled?: boolean;
}
const { href, id, title, desc, meta, icon, disabled = false } = Astro.props;
---
<a
  class="instrument"
  href={disabled ? undefined : href}
  aria-disabled={disabled ? 'true' : undefined}
>
  <div class="instrument__head">
    <span class="instrument__icon" aria-hidden="true">
      {icon === 'board' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <rect x="1.5" y="1.5" width="6" height="6"/><rect x="10.5" y="1.5" width="6" height="6"/>
          <rect x="1.5" y="10.5" width="6" height="6"/><rect x="10.5" y="10.5" width="6" height="6"/>
        </svg>
      )}
      {icon === 'atlas' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="9" cy="9" r="7"/><path d="M2 9h14M9 2c2.5 2 2.5 12 0 14M9 2c-2.5 2-2.5 12 0 14"/>
        </svg>
      )}
      {icon === 'timeline' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M1.5 9h15"/><circle cx="4.5" cy="9" r="1.5"/><circle cx="9" cy="9" r="1.5"/><circle cx="13.5" cy="9" r="1.5"/>
        </svg>
      )}
      {icon === 'map' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M1.5 3.5l5-1.5 5 2 5-1.5v12l-5 1.5-5-2-5 1.5z"/><path d="M6.5 2v12M11.5 4v12"/>
        </svg>
      )}
      {icon === 'graph' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="4" cy="4" r="1.8"/><circle cx="14" cy="4" r="1.8"/><circle cx="9" cy="14" r="1.8"/>
          <path d="M4 4l5 10M14 4l-5 10M4 4h10"/>
        </svg>
      )}
      {icon === 'vault' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <rect x="2" y="3" width="14" height="12"/><path d="M2 7h14M2 11h14"/><circle cx="14" cy="9" r="0.8" fill="currentColor"/>
        </svg>
      )}
      {icon === 'start' && (
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.2">
          <circle cx="9" cy="9" r="7"/><path d="M9 5v4l3 2"/>
        </svg>
      )}
    </span>
    <span class="instrument__id">{id}</span>
  </div>
  <h3 class="instrument__title">{title}</h3>
  <p class="instrument__desc">{desc}</p>
  <div class="instrument__footer">
    <span>{meta ?? ''}</span>
    <span class="instrument__open">{disabled ? 'Mining' : 'Enter →'}</span>
  </div>
</a>
