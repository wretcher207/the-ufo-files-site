---
import type { Thread } from '../lib/threads';

interface Props {
  thread: Thread;
  caseCount: number;
}
const { thread, caseCount } = Astro.props;
---
<article class="thread-card" data-archive={thread.archive}>
  <div class="thread-card__chrome">
    <span class="thread-card__serial">{thread.serial}</span>
    <span class="thread-card__archive">{thread.archive === 'pursue' ? 'PURSUE' : 'FBI'}</span>
  </div>
  <h3 class="thread-card__title">{thread.title}</h3>
  <p class="thread-card__span">{thread.span}</p>
  <p class="thread-card__blurb">{thread.blurb}</p>
  <div class="thread-card__footer">
    <span class="thread-card__count">{caseCount} case{caseCount === 1 ? '' : 's'}</span>
    <a class="thread-card__link" href={`/thread/${thread.id}`} aria-label={`Open thread ${thread.title}`}>
      Open dossier &nbsp;→
    </a>
  </div>
</article>

<style>
  .thread-card {
    background: var(--bg-1);
    padding: var(--sp-6) var(--sp-5) var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    transition: background var(--dur-fast) var(--ease-out), transform var(--dur-base) var(--ease-out);
    border: none;
    border-top: 1px solid var(--border);
    position: relative;
  }
  .thread-card:hover {
    background: var(--bg-2);
  }
  .thread-card[data-archive='pursue'] {
    border-top-color: var(--crt-glow);
  }
  .thread-card__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .thread-card__archive {
    color: var(--fg-2);
  }
  .thread-card[data-archive='pursue'] .thread-card__archive {
    color: var(--crt-glow);
  }
  .thread-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
    margin: 0;
    font-weight: 500;
  }
  .thread-card__span {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--fg-3);
    margin: 0;
  }
  .thread-card__blurb {
    font-family: var(--font-ui);
    font-size: var(--fs-base);
    line-height: var(--lh-normal);
    color: var(--fg-2);
    margin: var(--sp-2) 0 var(--sp-4);
  }
  .thread-card__footer {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-top: auto;
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--sp-4);
  }
  .thread-card__count {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-3);
  }
  .thread-card__link {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-1);
  }
  .thread-card__link:hover {
    color: var(--crt-glow);
  }
</style>
