---
import type { AnyCase } from '../lib/case-utils';
import { archiveOf, headlineDate, threadOf, tidyTitle } from '../lib/case-utils';

interface Props { entry: AnyCase; }
const { entry } = Astro.props;

const archive = archiveOf(entry);
const date = headlineDate(entry);
const thread = threadOf(entry);
const significance = entry.data.significance;
const publisher = entry.data.publisher;
const tags = entry.data.tags ?? [];
---
<header class="dh">
  <div class="dh__breadcrumb">
    <a href="/">Case board</a>
    <span aria-hidden="true">/</span>
    <a href={thread ? `/thread/${thread.id}` : '/'}>{thread?.title ?? 'Unfiled'}</a>
    <span aria-hidden="true">/</span>
    <span class="dh__breadcrumb-current">{tidyTitle(entry.data.title)}</span>
  </div>

  <div class="dh__chrome">
    <span class="dh__serial">{archive === 'pursue' ? 'PURSUE / WAR.GOV/UFO' : 'FBI 62-HQ-83894'}</span>
    {significance && <span class={`dh__sig dh__sig--${significance}`}>{significance.toUpperCase()} SIGNIFICANCE</span>}
  </div>

  <h1 class="dh__title">{tidyTitle(entry.data.title)}</h1>

  <dl class="dh__meta">
    {date && (
      <div>
        <dt>Date</dt>
        <dd>{date}</dd>
      </div>
    )}
    {publisher && (
      <div>
        <dt>Source agency</dt>
        <dd>{publisher}</dd>
      </div>
    )}
    {tags.length > 0 && (
      <div>
        <dt>Tags</dt>
        <dd class="dh__tags">{tags.slice(0, 8).join(' · ')}</dd>
      </div>
    )}
  </dl>
</header>

<style>
  .dh {
    border-top: 1px solid var(--border);
    padding-top: var(--sp-5);
    margin-bottom: var(--sp-7);
  }
  .dh__breadcrumb {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--fg-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    align-items: center;
    margin-bottom: var(--sp-5);
  }
  .dh__breadcrumb a { color: var(--fg-2); text-decoration: none; }
  .dh__breadcrumb a:hover { color: var(--crt-glow); }
  .dh__breadcrumb-current { color: var(--fg-3); }

  .dh__chrome {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
    margin-bottom: var(--sp-4);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }
  .dh__serial {
    color: var(--fg-2);
    border: 1px solid var(--border);
    padding: 4px 10px;
  }
  .dh__sig {
    padding: 4px 10px;
    border: 1px solid var(--border);
    color: var(--fg-3);
  }
  .dh__sig--high {
    color: var(--crt-glow);
    border-color: rgba(199, 247, 255, 0.4);
  }
  .dh__sig--medium { color: var(--fg-2); }
  .dh__sig--low { color: var(--fg-3); }

  .dh__title {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--fg-1);
    margin: 0 0 var(--sp-5);
    font-weight: 500;
    max-width: 30ch;
  }
  @media (max-width: 640px) {
    .dh__title { font-size: var(--fs-xl); max-width: none; }
  }

  .dh__meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--sp-4);
    margin: 0;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border-subtle);
  }
  .dh__meta div { display: flex; flex-direction: column; gap: var(--sp-1); }
  .dh__meta dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--fg-3);
    margin: 0;
  }
  .dh__meta dd {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--fg-1);
    margin: 0;
    word-break: break-word;
  }
  .dh__tags { color: var(--fg-2) !important; line-height: var(--lh-snug); }
</style>
