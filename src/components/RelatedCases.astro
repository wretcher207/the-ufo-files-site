---
/**
 * RelatedCases.astro
 *
 * Grid of related case cards built from `relationships[]` if present,
 * otherwise from the legacy entity-overlap heuristic via `relatedCases()`.
 *
 * Each card has a relationship-type chip, title, date, agency.
 */
import type { AnyCase } from '../lib/case-utils';
import { archiveOf, caseUrl, headlineDate, relatedCases, tidyTitle } from '../lib/case-utils';

interface Props {
  current: AnyCase;
  all: AnyCase[];
}
const { current, all } = Astro.props;

type RelType =
  | 'mentions' | 'supports' | 'contradicts'
  | 'same_location' | 'same_date' | 'same_agency'
  | 'derived_from' | 'occurred_before' | 'classified_under';

interface Card {
  entry: AnyCase;
  type: RelType;
  confidence?: 'low' | 'medium' | 'high';
}

const rels = current.data.relationships ?? [];
const byId = new Map<string, AnyCase>(all.map((c) => [c.id, c]));

const cards: Card[] = [];
for (const r of rels) {
  const target = String(r.target).trim();
  // Targets can be raw slugs or `slug.md` or `[label](slug.md)`. Best-effort.
  const cleaned = target
    .replace(/^\[.*?\]\(/, '')
    .replace(/\)$/, '')
    .replace(/\.md$/, '');
  const hit = byId.get(cleaned) ||
              all.find((c) => c.id === cleaned) ||
              all.find((c) => c.id.endsWith(cleaned));
  if (hit && hit.id !== current.id) {
    cards.push({ entry: hit, type: r.type as RelType, confidence: r.confidence });
  }
  if (cards.length >= 6) break;
}

// Fallback to entity-overlap if we have no explicit relationships.
if (cards.length === 0) {
  for (const e of relatedCases(current, all, 6)) {
    cards.push({ entry: e, type: 'mentions' });
  }
}

const seen = new Set<string>();
const dedup: Card[] = [];
for (const c of cards) {
  if (seen.has(c.entry.id)) continue;
  seen.add(c.entry.id);
  dedup.push(c);
}

function typeLabel(t: RelType): string {
  switch (t) {
    case 'mentions': return 'Mentions';
    case 'supports': return 'Supports';
    case 'contradicts': return 'Contradicts';
    case 'same_location': return 'Same location';
    case 'same_date': return 'Same date';
    case 'same_agency': return 'Same agency';
    case 'derived_from': return 'Derived from';
    case 'occurred_before': return 'Occurred before';
    case 'classified_under': return 'Classified under';
  }
}
---
{dedup.length > 0 && (
  <section class="related rule" aria-labelledby="related-heading">
    <header class="related__head">
      <span class="related__label">RELATED CASES</span>
      <h2 id="related-heading" class="related__title">Files that talk to this one</h2>
    </header>

    <ul class="related__grid">
      {dedup.map((c) => {
        const archive = archiveOf(c.entry);
        const date = headlineDate(c.entry);
        const agency = (typeof c.entry.data.agency === 'string' && c.entry.data.agency) ||
          (typeof c.entry.data.publisher === 'string' ? c.entry.data.publisher : '');
        return (
          <li class="related__item">
            <a href={caseUrl(c.entry)}>
              <span class={`related__chip related__chip--${c.type}`}>{typeLabel(c.type)}</span>
              <span class="related__case-title">{tidyTitle(c.entry.data.title)}</span>
              <span class="related__case-meta">
                <span>{date || '—'}</span>
                <span class="related__sep">·</span>
                <span>{archive === 'pursue' ? 'PURSUE' : 'FBI'}</span>
                {agency && (<>
                  <span class="related__sep">·</span>
                  <span>{agency}</span>
                </>)}
              </span>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}

<style>
  .related {
    margin-top: var(--sp-8);
    padding-top: var(--sp-5);
  }
  .related__head { margin-bottom: var(--sp-5); display: flex; flex-direction: column; gap: var(--sp-2); }
  .related__label {
    font-family: var(--font-mono);
    font-weight: var(--weight-mono-md);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .related__title {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    letter-spacing: var(--tracking-tight);
    color: var(--ink-primary);
    margin: 0;
    line-height: var(--lh-snug);
  }
  .related__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-4);
  }
  .related__item {}
  .related__item a {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4);
    background: var(--bg-raised);
    border: 1px solid var(--rule);
    text-decoration: none;
    color: var(--ink-primary);
    height: 100%;
    transition:
      border-color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }
  .related__item a:hover {
    border-color: var(--accent-amber);
    transform: translateY(-1px);
  }
  .related__item a:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }
  .related__chip {
    display: inline-flex;
    align-self: flex-start;
    padding: 2px 8px;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--ink-secondary);
    border: 1px solid var(--rule);
  }
  .related__chip--supports,
  .related__chip--derived_from { color: var(--accent-amber); border-color: var(--accent-amber); }
  .related__chip--contradicts { color: var(--accent-verdigris); border-color: var(--accent-verdigris); }
  .related__case-title {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    line-height: var(--lh-snug);
    color: var(--ink-primary);
  }
  .related__case-meta {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-1);
    align-items: center;
  }
  .related__sep { opacity: 0.5; }
</style>
